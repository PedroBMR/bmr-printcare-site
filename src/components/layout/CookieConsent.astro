---
import { withBase } from '../../utils/paths';

const rawMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const measurementId = typeof rawMeasurementId === 'string' ? rawMeasurementId.trim() : '';
const isValidMeasurementId = /^G-[A-Z0-9]{6,20}$/.test(measurementId);
---

{
  isValidMeasurementId && (
    <section
      class="cookie-consent"
      data-cookie-consent
      aria-labelledby="cookie-consent-title"
      hidden
    >
      <div class="cookie-consent__panel" role="region" aria-describedby="cookie-consent-copy">
        <div class="cookie-consent__copy">
          <h2 id="cookie-consent-title">Analytics cookie settings</h2>
          <p id="cookie-consent-copy">
            Basic analytics cookies help us understand website traffic. You can accept or reject analytics cookies, and the Privacy Notice explains the details.
          </p>
        </div>
        <div class="cookie-consent__actions" aria-label="Analytics consent choices">
          <button class="cookie-consent__button cookie-consent__button--primary" type="button" data-cookie-accept>
            Accept analytics
          </button>
          <button class="cookie-consent__button" type="button" data-cookie-reject>
            Reject
          </button>
          <a class="cookie-consent__link" href={withBase('/privacy/')}>Privacy Notice</a>
        </div>
      </div>
    </section>
  )
}

{
  isValidMeasurementId && (
    <script is:inline>
  (() => {
    const configElement = document.getElementById('nozzlenote-analytics-config');
    const consentElement = document.querySelector('[data-cookie-consent]');

    if (!configElement || !consentElement) {
      return;
    }

    let config;
    try {
      config = JSON.parse(configElement.textContent || '{}');
    } catch {
      return;
    }

    const measurementId = typeof config.measurementId === 'string' ? config.measurementId.trim() : '';
    const consentKey = config.consentKey || 'nozzlenote_analytics_consent';
    const gtagSource = config.gtagSource;

    if (!/^G-[A-Z0-9]{6,20}$/.test(measurementId) || typeof gtagSource !== 'string') {
      return;
    }

    const acceptedValue = 'accepted';
    const rejectedValue = 'rejected';
    const acceptButton = consentElement.querySelector('[data-cookie-accept]');
    const rejectButton = consentElement.querySelector('[data-cookie-reject]');
    const gaDisableKey = `ga-disable-${measurementId}`;
    let analyticsLoaded = false;

    const getPreference = () => {
      try {
        return window.localStorage.getItem(consentKey);
      } catch {
        return null;
      }
    };

    const setPreference = (value) => {
      try {
        window.localStorage.setItem(consentKey, value);
      } catch {
        document.cookie = `${consentKey}=${value}; Path=/; Max-Age=31536000; SameSite=Lax`;
      }
    };

    const removeCookie = (name) => {
      document.cookie = `${name}=; Path=/; Expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax`;
      const hostParts = window.location.hostname.split('.');
      if (hostParts.length > 1) {
        document.cookie = `${name}=; Path=/; Domain=.${hostParts.slice(-2).join('.')}; Expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax`;
      }
    };

    const clearAnalyticsCookies = () => {
      removeCookie('_ga');
      removeCookie(`_ga_${measurementId.replace('G-', '')}`);
      removeCookie('_gid');
      removeCookie('_gat');
    };

    const hideBanner = () => {
      consentElement.hidden = true;
    };

    const showBanner = () => {
      consentElement.hidden = false;
    };

    const loadAnalytics = () => {
      window[gaDisableKey] = false;

      if (analyticsLoaded || document.querySelector('script[data-nozzlenote-ga4]')) {
        analyticsLoaded = true;
        return;
      }

      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function gtag(){window.dataLayer.push(arguments);};
      window.gtag('js', new Date());
      window.gtag('config', measurementId);

      const script = document.createElement('script');
      script.async = true;
      script.src = gtagSource;
      script.dataset.nozzlenoteGa4 = 'true';
      document.head.appendChild(script);
      analyticsLoaded = true;
    };

    const acceptAnalytics = () => {
      setPreference(acceptedValue);
      hideBanner();
      loadAnalytics();
    };

    const rejectAnalytics = () => {
      setPreference(rejectedValue);
      window[gaDisableKey] = true;
      document.querySelectorAll('script[data-nozzlenote-ga4]').forEach((script) => script.remove());
      analyticsLoaded = false;
      hideBanner();
      clearAnalyticsCookies();
    };

    acceptButton?.addEventListener('click', acceptAnalytics);
    rejectButton?.addEventListener('click', rejectAnalytics);

    window.addEventListener('nozzlenote:open-cookie-settings', () => {
      showBanner();
      acceptButton?.focus({ preventScroll: true });
    });

    window[gaDisableKey] = true;

    const preference = getPreference();
    if (preference === acceptedValue) {
      loadAnalytics();
      hideBanner();
      return;
    }

    if (preference === rejectedValue) {
      clearAnalyticsCookies();
      hideBanner();
      return;
    }

    showBanner();
  })();
</script>
  )
}

<style>
  .cookie-consent[hidden] {
    display: none;
  }

  .cookie-consent {
    position: fixed;
    z-index: 50;
    right: var(--space-page);
    bottom: var(--space-page);
    left: var(--space-page);
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  .cookie-consent__panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    width: min(100%, 64rem);
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: 1.25rem;
    padding: 1rem;
    background: rgba(7, 10, 18, 0.96);
    box-shadow: var(--shadow-soft), 0 0 0 1px rgba(255, 255, 255, 0.04);
    pointer-events: auto;
  }

  .cookie-consent__copy {
    display: grid;
    gap: 0.35rem;
  }

  .cookie-consent h2,
  .cookie-consent p {
    margin: 0;
  }

  .cookie-consent h2 {
    color: var(--color-text);
    font-size: 1rem;
    letter-spacing: -0.01em;
  }

  .cookie-consent p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.42;
  }

  .cookie-consent__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    justify-content: flex-end;
  }

  .cookie-consent__button,
  .cookie-consent__link {
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 999px;
    padding: 0.7rem 0.95rem;
    background: rgba(16, 22, 36, 0.82);
    color: var(--color-text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
  }

  .cookie-consent__button--primary {
    border-color: rgba(57, 208, 255, 0.42);
    background: linear-gradient(135deg, rgba(57, 208, 255, 0.24), rgba(124, 58, 237, 0.28));
  }

  .cookie-consent__button:hover,
  .cookie-consent__button:focus-visible,
  .cookie-consent__link:hover,
  .cookie-consent__link:focus-visible {
    border-color: rgba(57, 208, 255, 0.55);
    color: var(--color-text);
  }

  @media (max-width: 760px) {
    .cookie-consent {
      right: 0.75rem;
      bottom: 0.75rem;
      left: 0.75rem;
    }

    .cookie-consent__panel {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      max-height: min(62vh, 24rem);
      overflow: auto;
      border-radius: 1rem;
      padding: 0.8rem;
    }

    .cookie-consent h2 {
      font-size: 0.95rem;
    }

    .cookie-consent p {
      font-size: 0.86rem;
    }

    .cookie-consent__actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
      justify-content: stretch;
    }

    .cookie-consent__button,
    .cookie-consent__link {
      min-height: 2.65rem;
      padding: 0.68rem 0.72rem;
      text-align: center;
    }

    .cookie-consent__link {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 380px) {
    .cookie-consent__actions {
      grid-template-columns: 1fr;
    }
  }
</style>
