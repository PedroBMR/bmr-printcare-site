---
import { normalizeRoute, withBase } from '../../utils/paths';
const navigationItems = [
  { label: 'Home', href: '/' },
  { label: 'Features', href: '/features/' },
  { label: 'Docs', href: '/docs/' },
  { label: 'Catalogs', href: '/catalogs/' },
  { label: 'Roadmap', href: '/roadmap/' },
  { label: 'Download', href: '/download/' },
  { label: 'Support', href: '/support/' },
];

const normalizedPath = normalizeRoute(Astro.url.pathname);
---

<header class="site-header" role="banner">
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="brand-link" href={withBase('/')} aria-label="NozzleNote by BMR home">
      <span class="brand-mark" aria-hidden="true">
        <img
          src={withBase('/brand/nozzlenote-nn-symbol-64.png')}
          alt=""
          width="64"
          height="64"
          loading="eager"
          decoding="async"
        />
      </span>
      <span class="brand-text">
        <strong>NozzleNote</strong>
        <span>by BMR</span>
      </span>
    </a>

    <div class="nav-links" aria-label="Primary site sections">
      {navigationItems.map((item) => {
        const normalizedHref = item.href.endsWith('/') ? item.href : `${item.href}/`;
        const isActive = normalizedPath === normalizedHref;

        return (
          <a href={withBase(item.href)} aria-current={isActive ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    background:
      linear-gradient(90deg, rgba(57, 208, 255, 0.07), transparent 28%, rgba(124, 58, 237, 0.06)),
      rgba(7, 10, 18, 0.86);
    backdrop-filter: blur(18px);
  }

  .site-nav {
    display: flex;
    width: min(100%, 76rem);
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    margin: 0 auto;
    padding: 0.78rem var(--space-page);
  }

  .brand-link {
    display: inline-flex;
    min-width: max-content;
    align-items: center;
    gap: 0.72rem;
    border-radius: 1rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      color var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .brand-link:hover,
  .brand-link:focus-visible {
    transform: translateY(var(--motion-hover-raise));
  }

  .brand-mark {
    display: inline-grid;
    width: 2.65rem;
    height: 2.65rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: 0.95rem;
    background:
      radial-gradient(circle at 30% 20%, rgba(57, 208, 255, 0.14), transparent 62%),
      rgba(16, 22, 36, 0.72);
    box-shadow: 0 16px 42px rgba(57, 208, 255, 0.13), 0 12px 36px rgba(124, 58, 237, 0.1);
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-glow) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .brand-link:hover .brand-mark,
  .brand-link:focus-visible .brand-mark {
    border-color: rgba(57, 208, 255, 0.48);
    box-shadow: 0 18px 48px rgba(57, 208, 255, 0.18), 0 14px 42px rgba(124, 58, 237, 0.14);
  }

  .brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .brand-text {
    display: grid;
    gap: 0.08rem;
  }

  .brand-text strong {
    font-size: 0.98rem;
    line-height: 1.1;
  }

  .brand-text span {
    color: var(--color-text-soft);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .nav-links {
    display: flex;
    min-width: 0;
    justify-content: flex-end;
    gap: 0.25rem;
  }

  .nav-links a {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.5rem 0.68rem;
    color: var(--color-text-muted);
    font-size: clamp(0.78rem, 1vw, 0.88rem);
    font-weight: 850;
    line-height: 1;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      background var(--motion-duration-base) var(--motion-ease-standard),
      color var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .brand-link:focus-visible,
  .nav-links a:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 0.22rem;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .nav-links a[aria-current='page'] {
    border-color: rgba(57, 208, 255, 0.26);
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    transform: translateY(var(--motion-hover-raise));
  }

  @media (max-width: 920px) {
    .site-nav {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.7rem;
    }

    .nav-links {
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.18rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(57, 208, 255, 0.45) transparent;
    }

    .nav-links a {
      flex: 0 0 auto;
      padding: 0.55rem 0.78rem;
    }
  }

  @media (max-width: 520px) {
    .site-nav {
      padding-block: 0.7rem;
    }

    .brand-mark {
      width: 2.35rem;
      height: 2.35rem;
    }
  }
</style>
