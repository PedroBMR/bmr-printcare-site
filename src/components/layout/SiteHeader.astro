---
import { normalizeRoute, withBase } from '../../utils/paths';
const navigationItems = [
  { label: 'Home', href: '/' },
  { label: 'Features', href: '/features/' },
  { label: 'Docs', href: '/docs/' },
  { label: 'Catalogs', href: '/catalogs/' },
  { label: 'Pricing', href: '/pricing/' },
  { label: 'Roadmap', href: '/roadmap/' },
  { label: 'Download', href: '/download/' },
  { label: 'Support', href: '/support/' },
];

const normalizedPath = normalizeRoute(Astro.url.pathname);
---

<header class="site-header" role="banner">
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="brand-link" href={withBase('/')} aria-label="NozzleNote by BMR home">
      <span class="brand-mark" aria-hidden="true">
        <img
          src={withBase('/brand/nozzlenote-nn-symbol-64.png')}
          alt=""
          width="64"
          height="64"
          loading="eager"
          decoding="async"
        />
      </span>
      <span class="brand-text">
        <strong>NozzleNote</strong>
        <span>by BMR</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation-links"
      aria-label="Open primary navigation"
      data-nav-toggle
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <div class="nav-links" id="primary-navigation-links" aria-label="Primary site sections" data-nav-links>
      {navigationItems.map((item) => {
        const normalizedHref = item.href.endsWith('/') ? item.href : `${item.href}/`;
        const isActive = normalizedPath === normalizedHref;

        return (
          <a href={withBase(item.href)} aria-current={isActive ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>


<script is:inline>
  (() => {
    const toggle = document.querySelector('[data-nav-toggle]');
    const links = document.querySelector('[data-nav-links]');

    if (!toggle || !links) {
      return;
    }

    const setMenuState = (isOpen) => {
      toggle.setAttribute('aria-expanded', String(isOpen));
      toggle.setAttribute('aria-label', isOpen ? 'Close primary navigation' : 'Open primary navigation');
      links.toggleAttribute('data-open', isOpen);
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setMenuState(!isOpen);
    });

    links.addEventListener('click', (event) => {
      if (event.target instanceof HTMLAnchorElement) {
        setMenuState(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMenuState(false);
        toggle.focus({ preventScroll: true });
      }
    });

    document.addEventListener('click', (event) => {
      if (!toggle.contains(event.target) && !links.contains(event.target)) {
        setMenuState(false);
      }
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    background:
      linear-gradient(90deg, rgba(57, 208, 255, 0.07), transparent 28%, rgba(124, 58, 237, 0.06)),
      rgba(7, 10, 18, 0.86);
    box-shadow: 0 1px 0 rgba(57, 208, 255, 0.08), 0 18px 54px rgba(7, 10, 18, 0.32);
    backdrop-filter: blur(18px);
  }

  .site-header::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 1px;
    opacity: 0.82;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(57, 208, 255, 0.44), rgba(124, 58, 237, 0.28), transparent);
    background-size: 220% 100%;
    content: '';
  }

  .site-nav {
    display: flex;
    width: min(100%, 76rem);
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    margin: 0 auto;
    padding: 0.78rem var(--space-page);
  }

  .brand-link {
    display: inline-flex;
    min-width: max-content;
    align-items: center;
    gap: 0.72rem;
    border-radius: 1rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      color var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .brand-link:hover,
  .brand-link:focus-visible {
    transform: translateY(var(--motion-hover-raise));
  }

  .brand-mark {
    display: inline-grid;
    width: 2.65rem;
    height: 2.65rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: 0.95rem;
    background:
      radial-gradient(circle at 30% 20%, rgba(57, 208, 255, 0.14), transparent 62%),
      rgba(16, 22, 36, 0.72);
    box-shadow: 0 16px 42px rgba(57, 208, 255, 0.13), 0 12px 36px rgba(124, 58, 237, 0.1);
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-glow) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .brand-link:hover .brand-mark,
  .brand-link:focus-visible .brand-mark {
    border-color: rgba(57, 208, 255, 0.48);
    box-shadow: 0 18px 48px rgba(57, 208, 255, 0.18), 0 14px 42px rgba(124, 58, 237, 0.14);
  }

  .brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .brand-text {
    display: grid;
    gap: 0.08rem;
  }

  .brand-text strong {
    font-size: 0.98rem;
    line-height: 1.1;
  }

  .brand-text span {
    color: var(--color-text-soft);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .nav-toggle {
    display: none;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 0.9rem;
    padding: 0.62rem;
    background: rgba(16, 22, 36, 0.78);
    color: var(--color-text);
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    width: 1.25rem;
    height: 0.13rem;
    border-radius: 999px;
    background: currentColor;
  }

  .nav-toggle span + span {
    margin-top: 0.28rem;
  }

  .nav-links {
    display: flex;
    min-width: 0;
    justify-content: flex-end;
    gap: 0.25rem;
  }

  .nav-links a {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.5rem 0.68rem;
    color: var(--color-text-muted);
    font-size: clamp(0.78rem, 1vw, 0.88rem);
    font-weight: 850;
    line-height: 1;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      background var(--motion-duration-base) var(--motion-ease-standard),
      color var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .brand-link:focus-visible,
  .nav-toggle:focus-visible,
  .nav-links a:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 0.22rem;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .nav-links a[aria-current='page'] {
    border-color: rgba(57, 208, 255, 0.26);
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    transform: translateY(var(--motion-hover-raise));
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-header::after {
      animation: header-edge-glow var(--motion-duration-light-sweep) var(--motion-ease-ambient) infinite alternate;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header::after {
      animation: none;
    }
  }

  @keyframes header-edge-glow {
    from {
      background-position: 0% 50%;
      opacity: 0.5;
    }

    to {
      background-position: 100% 50%;
      opacity: 0.86;
    }
  }

  @media (max-width: 920px) {
    .site-nav {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.7rem;
    }

    .nav-toggle {
      display: inline-flex;
      flex-direction: column;
      align-self: center;
    }

    .nav-links {
      position: absolute;
      top: calc(100% + 0.45rem);
      right: var(--space-page);
      left: var(--space-page);
      display: none;
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem;
      border: 1px solid rgba(57, 208, 255, 0.2);
      border-radius: 1.15rem;
      padding: 0.65rem;
      background: rgba(7, 10, 18, 0.98);
      box-shadow: var(--shadow-soft), 0 18px 54px rgba(7, 10, 18, 0.42);
    }

    .nav-links[data-open] {
      display: grid;
    }

    .nav-links a {
      padding: 0.78rem 0.86rem;
      background: rgba(16, 22, 36, 0.56);
      text-align: left;
    }
  }

  @media (max-width: 520px) {
    .site-nav {
      padding-block: 0.7rem;
    }

    .nav-links {
      grid-template-columns: 1fr;
    }

    .brand-mark {
      width: 2.35rem;
      height: 2.35rem;
    }
  }
</style>
