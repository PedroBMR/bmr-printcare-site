---
import { normalizeRoute, withBase } from '../../utils/paths';
const navigationItems = [
  { label: 'Home', href: '/' },
  { label: 'Features', href: '/features/' },
  { label: 'Docs', href: '/docs/' },
  { label: 'Catalogs', href: '/catalogs/' },
  { label: 'Roadmap', href: '/roadmap/' },
  { label: 'Download', href: '/download/' },
  { label: 'Support', href: '/support/' },
];

const normalizedPath = normalizeRoute(Astro.url.pathname);
---

<header class="site-header" role="banner">
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="brand-link" href={withBase('/')} aria-label="PrintKeep by BMR home">
      <span class="brand-mark" aria-hidden="true">PK</span>
      <span class="brand-text">
        <strong>PrintKeep</strong>
        <span>by BMR</span>
      </span>
    </a>

    <div class="nav-links" aria-label="Primary site sections">
      {navigationItems.map((item) => {
        const normalizedHref = item.href.endsWith('/') ? item.href : `${item.href}/`;
        const isActive = normalizedPath === normalizedHref;

        return (
          <a href={withBase(item.href)} aria-current={isActive ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(7, 10, 18, 0.84);
    backdrop-filter: blur(18px);
  }

  .site-nav {
    display: flex;
    width: min(100%, 76rem);
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    margin: 0 auto;
    padding: 0.78rem var(--space-page);
  }

  .brand-link {
    display: inline-flex;
    min-width: max-content;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: 2.45rem;
    height: 2.45rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(57, 208, 255, 0.38);
    border-radius: 0.85rem;
    background: linear-gradient(135deg, rgba(57, 208, 255, 0.16), rgba(124, 58, 237, 0.2));
    color: var(--color-text);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    box-shadow: 0 16px 42px rgba(57, 208, 255, 0.12);
  }

  .brand-text {
    display: grid;
    gap: 0.08rem;
  }

  .brand-text strong {
    font-size: 0.98rem;
    line-height: 1.1;
  }

  .brand-text span {
    color: var(--color-text-soft);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    min-width: 0;
    justify-content: flex-end;
    gap: 0.25rem;
  }

  .nav-links a {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.5rem 0.68rem;
    color: var(--color-text-muted);
    font-size: clamp(0.78rem, 1vw, 0.88rem);
    font-weight: 850;
    line-height: 1;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .brand-link:focus-visible,
  .nav-links a:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 0.22rem;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .nav-links a[aria-current='page'] {
    border-color: rgba(57, 208, 255, 0.26);
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
  }

  @media (max-width: 920px) {
    .site-nav {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.7rem;
    }

    .nav-links {
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.18rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(57, 208, 255, 0.45) transparent;
    }

    .nav-links a {
      flex: 0 0 auto;
      padding: 0.55rem 0.78rem;
    }
  }

  @media (max-width: 520px) {
    .site-nav {
      padding-block: 0.7rem;
    }

    .brand-mark {
      width: 2.25rem;
      height: 2.25rem;
    }
  }
</style>
