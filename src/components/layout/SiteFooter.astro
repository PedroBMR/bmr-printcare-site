---
const productLinks = [
  { label: 'Home', href: '/' },
  { label: 'Features', href: '/features/' },
  { label: 'Roadmap', href: '/roadmap/' },
  { label: 'Download status', href: '/download/' },
  { label: 'Support', href: '/support/' },
];

const resourceLinks = [
  { label: 'Documentation hub', href: '/docs/' },
  { label: 'Release preparation', href: '/download/' },
  { label: 'Feature overview', href: '/features/' },
  { label: 'Maintenance workflow', href: '/#workflow' },
];

const legalLinks = [
  { label: 'Privacy notice', href: '/privacy/' },
  { label: 'Terms of use', href: '/terms/' },
  { label: 'License terms', href: '/license-terms/' },
  { label: 'Refund policy', href: '/refund-policy/' },
  { label: 'Manufacturer disclaimer', href: '/manufacturer-disclaimer/' },
];
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-shell">
    <section class="footer-brand" aria-labelledby="footer-brand-title">
      <p class="section-eyebrow">BMR PrintCare</p>
      <h2 id="footer-brand-title">Independent desktop maintenance tracking for 3D printer care.</h2>
      <p>
        Public release is planned, but the app is not publicly available yet. Website content and documentation are being
        prepared in small, transparent milestones.
      </p>
    </section>

    <div class="footer-links" aria-label="Footer navigation">
      <div>
        <h3>Product</h3>
        <ul>
          {productLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3>Resources</h3>
        <ul>
          {resourceLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3>Legal drafts</h3>
        <ul aria-label="Draft legal routes">
          {legalLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        BMR PrintCare is independent and is not affiliated with, endorsed by, sponsored by, or officially connected to
        any 3D printer manufacturer.
      </p>
      <p>&copy; {currentYear} BMR PrintCare. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(7, 10, 18, 0.72);
  }

  .footer-shell {
    display: grid;
    width: min(100%, 76rem);
    gap: 2rem;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 5rem) var(--space-page) 2rem;
  }

  .footer-brand {
    display: grid;
    gap: 1rem;
    max-width: 48rem;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 3.25rem);
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .footer-brand p:not(.section-eyebrow),
  .footer-bottom p {
    color: var(--color-text-muted);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .footer-links > div {
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 1.15rem;
    background: rgba(16, 22, 36, 0.52);
  }

  h3 {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  ul {
    display: grid;
    gap: 0.65rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  a {
    color: var(--color-text-muted);
    text-decoration-color: transparent;
    text-underline-offset: 0.25em;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-text);
    text-decoration-color: rgba(57, 208, 255, 0.55);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
    font-size: 0.9rem;
  }

  .footer-bottom p:first-child {
    max-width: 48rem;
  }

  @media (max-width: 900px) {
    .footer-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
