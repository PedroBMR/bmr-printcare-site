---
import { withBase } from '../../utils/paths';

const primaryLinks = [
  { label: 'Home', href: '/' },
  { label: 'Features', href: '/features/' },
  { label: 'Docs', href: '/docs/' },
  { label: 'Support', href: '/support/' },
];

const planningLinks = [
  { label: 'Catalog planning', href: '/catalogs/' },
  { label: 'Roadmap', href: '/roadmap/' },
  { label: 'Release preparation', href: '/download/' },
  { label: 'Early Supporters concept', href: '/early-supporters/' },
];

const legalLinks = [
  { label: 'Privacy notice', href: '/privacy/' },
  { label: 'Terms of use', href: '/terms/' },
  { label: 'License terms', href: '/license-terms/' },
  { label: 'Refund policy', href: '/refund-policy/' },
  { label: 'Manufacturer disclaimer', href: '/manufacturer-disclaimer/' },
];
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-shell">
    <section class="footer-brand" aria-labelledby="footer-brand-title">
      <p class="section-eyebrow">NozzleNote by BMR</p>
      <h2 id="footer-brand-title">Independent desktop maintenance tracking for 3D printer care.</h2>
      <p>
        Public release is planned, but the app is not publicly available yet. Website content and documentation are being
        prepared in small, transparent milestones.
      </p>
    </section>

    <div class="footer-links" aria-label="Footer navigation">
      <div>
        <h3>Start here</h3>
        <ul>
          {primaryLinks.map((link) => (
            <li><a href={withBase(link.href)}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3>Planning status</h3>
        <ul>
          {planningLinks.map((link) => (
            <li><a href={withBase(link.href)}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3>Legal drafts</h3>
        <ul aria-label="Draft legal routes">
          {legalLinks.map((link) => (
            <li><a href={withBase(link.href)}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        NozzleNote by BMR is an independent product and is not affiliated with, endorsed by, sponsored by, or officially
        connected to Bambu Lab, Creality, Anycubic, Prusa, or any other 3D printer manufacturer.
      </p>
      <p>&copy; {currentYear} NozzleNote by BMR. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(7, 10, 18, 0.72);
  }

  .footer-shell {
    display: grid;
    width: min(100%, 76rem);
    gap: 2rem;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 5rem) var(--space-page) 2rem;
  }

  .footer-brand {
    display: grid;
    gap: 1rem;
    max-width: 48rem;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 3.25rem);
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .footer-brand p:not(.section-eyebrow),
  .footer-bottom p {
    color: var(--color-text-muted);
  }

  .footer-links {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr) minmax(0, 1.15fr);
    gap: 1rem;
  }

  .footer-links > div {
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 1.15rem;
    background: rgba(16, 22, 36, 0.52);
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-glow) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .footer-links > div:hover,
  .footer-links > div:focus-within {
    border-color: rgba(57, 208, 255, 0.3);
    box-shadow: 0 16px 44px rgba(57, 208, 255, 0.08);
    transform: translateY(var(--motion-hover-raise));
  }

  h3 {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  ul {
    display: grid;
    gap: 0.58rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  a {
    color: var(--color-text-muted);
    line-height: 1.3;
    text-decoration-color: transparent;
    text-underline-offset: 0.25em;
    transition:
      color var(--motion-duration-base) var(--motion-ease-standard),
      text-decoration-color var(--motion-duration-base) var(--motion-ease-standard);
  }

  a:hover,
  a:focus-visible {
    color: var(--color-text);
    text-decoration-color: rgba(57, 208, 255, 0.55);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
    font-size: 0.9rem;
  }

  .footer-bottom p:first-child {
    max-width: 48rem;
  }

  @media (max-width: 900px) {
    .footer-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
