---
const rawMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const measurementId = typeof rawMeasurementId === 'string' ? rawMeasurementId.trim() : '';
const isValidMeasurementId = /^G-[A-Z0-9]{6,20}$/.test(measurementId);
const gtagSource = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
const gtagInlineScript = `
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '${measurementId}');
`;
---

{
  isValidMeasurementId && (
    <>
      <script is:inline async src={gtagSource}></script>
      <script is:inline set:html={gtagInlineScript}></script>
    </>
  )
}
