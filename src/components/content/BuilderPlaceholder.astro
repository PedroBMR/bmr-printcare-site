---
import { withBase } from '../../utils/paths';

interface Props {
  src?: string;
  alt: string;
  label?: string;
  note?: string;
  aspectRatio?: string;
  variant?: 'hero' | 'inline' | 'wide';
}

const {
  src,
  alt,
  label = 'The Builder visual',
  note,
  aspectRatio = '4 / 5',
  variant = 'inline',
} = Astro.props;

const imageSrc = src ? withBase(src) : undefined;
const hasImage = Boolean(imageSrc);
---

<figure
  class:list={['builder-placeholder', `builder-placeholder--${variant}`, { 'builder-placeholder--with-image': hasImage }]}
  style={`--builder-aspect-ratio: ${aspectRatio};`}
  aria-label={alt}
>
  <div class="builder-placeholder__stage">
    <div class="builder-placeholder__glow" aria-hidden="true"></div>
    {imageSrc ? (
      <img
        class="builder-placeholder__image"
        src={imageSrc}
        alt={alt}
        loading={variant === 'hero' ? 'eager' : 'lazy'}
        decoding="async"
        fetchpriority={variant === 'hero' ? 'high' : 'auto'}
        data-builder-image
      />
    ) : null}
    <div class="builder-placeholder__fallback" role="img" aria-label={alt} hidden={hasImage}>
      <div class="builder-placeholder__silhouette" aria-hidden="true">
        <span class="builder-placeholder__head"></span>
        <span class="builder-placeholder__body"></span>
        <span class="builder-placeholder__bench"></span>
      </div>
      <div class="builder-placeholder__content">
        <span class="builder-placeholder__kicker">Builder story</span>
        <strong>{label}</strong>
      </div>
    </div>
  </div>
  {note ? (
    <figcaption>
      <span>{note}</span>
    </figcaption>
  ) : null}
</figure>

<script is:inline>
  document.querySelectorAll('[data-builder-image]').forEach((image) => {
    const showFallback = () => {
      image.hidden = true;
      const fallback = image.nextElementSibling;
      if (fallback) {
        fallback.hidden = false;
      }
    };

    image.addEventListener('error', showFallback);

    if (image.complete && image.naturalWidth === 0) {
      showFallback();
    }
  });
</script>

<style>
  .builder-placeholder {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    min-width: 0;
  }

  .builder-placeholder__stage {
    position: relative;
    display: grid;
    min-height: 20rem;
    aspect-ratio: var(--builder-aspect-ratio);
    overflow: hidden;
    align-items: stretch;
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: calc(var(--radius-card) + 0.4rem);
    background:
      radial-gradient(circle at 50% 18%, rgba(57, 208, 255, 0.18), transparent 10rem),
      radial-gradient(circle at 78% 18%, rgba(124, 58, 237, 0.16), transparent 12rem),
      linear-gradient(145deg, rgba(10, 16, 30, 0.94), rgba(16, 22, 36, 0.76));
    box-shadow: var(--shadow-soft), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    isolation: isolate;
  }

  .builder-placeholder__stage::before,
  .builder-placeholder__stage::after {
    position: absolute;
    z-index: 2;
    pointer-events: none;
    content: '';
  }

  .builder-placeholder__stage::before {
    inset: 0;
    opacity: 0.34;
    background:
      linear-gradient(rgba(148, 163, 184, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.045) 1px, transparent 1px);
    background-size: 2.4rem 2.4rem;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.72), transparent 78%);
  }

  .builder-placeholder__stage::after {
    inset: auto 10% 8% 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(57, 208, 255, 0.58), rgba(167, 139, 250, 0.42), transparent);
    box-shadow: 0 0 34px rgba(57, 208, 255, 0.22);
  }

  .builder-placeholder__glow {
    position: absolute;
    z-index: -1;
    inset: 12% 5% auto;
    height: 45%;
    border-radius: 999px;
    opacity: 0.52;
    background: radial-gradient(ellipse, rgba(57, 208, 255, 0.2), rgba(124, 58, 237, 0.1) 42%, transparent 68%);
    filter: blur(18px);
  }

  .builder-placeholder__image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: saturate(1.04) contrast(1.03);
  }

  .builder-placeholder--hero .builder-placeholder__image {
    object-position: center center;
  }

  .builder-placeholder__fallback {
    position: relative;
    display: grid;
    min-height: inherit;
    padding: clamp(1.1rem, 3vw, 1.45rem);
    align-items: end;
  }

  .builder-placeholder__fallback[hidden] {
    display: none;
  }

  .builder-placeholder__silhouette {
    position: absolute;
    inset: 12% 16% 20%;
    display: grid;
    place-items: center;
    opacity: 0.88;
  }

  .builder-placeholder__head,
  .builder-placeholder__body,
  .builder-placeholder__bench {
    position: absolute;
    display: block;
    border: 1px solid rgba(57, 208, 255, 0.26);
    background: linear-gradient(180deg, rgba(57, 208, 255, 0.14), rgba(124, 58, 237, 0.08));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 20px 50px rgba(7, 10, 18, 0.48);
  }

  .builder-placeholder__head {
    top: 0;
    width: clamp(4.4rem, 10vw, 6.6rem);
    height: clamp(4.4rem, 10vw, 6.6rem);
    border-radius: 45% 45% 48% 48%;
  }

  .builder-placeholder__body {
    top: clamp(4.9rem, 11vw, 7.4rem);
    width: clamp(9rem, 20vw, 13.4rem);
    height: clamp(10rem, 23vw, 15.5rem);
    border-radius: 42% 42% 18% 18%;
    background:
      radial-gradient(circle at 50% 22%, rgba(57, 208, 255, 0.18), transparent 4rem),
      linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(20, 16, 39, 0.82));
  }

  .builder-placeholder__bench {
    right: 0;
    bottom: 0;
    left: 0;
    height: clamp(2.2rem, 5vw, 3.25rem);
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(57, 208, 255, 0.14), rgba(124, 58, 237, 0.1));
  }

  .builder-placeholder__content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.45rem;
    align-self: end;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 1.1rem;
    padding: 0.9rem;
    background: rgba(7, 10, 18, 0.72);
    backdrop-filter: blur(12px);
  }

  .builder-placeholder__kicker,
  figcaption {
    color: var(--color-text-soft);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .builder-placeholder__kicker {
    color: var(--color-accent);
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .builder-placeholder strong {
    color: var(--color-text);
    font-size: clamp(1.1rem, 2.4vw, 1.35rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  figcaption {
    margin: 0;
    padding: 0 0.15rem;
  }

  .builder-placeholder--hero .builder-placeholder__stage {
    min-height: clamp(24rem, 44vw, 32rem);
  }

  .builder-placeholder--wide .builder-placeholder__stage {
    min-height: 18rem;
  }

  @media (max-width: 640px) {
    .builder-placeholder__stage {
      min-height: 18rem;
    }

    .builder-placeholder--hero .builder-placeholder__stage {
      min-height: clamp(20rem, 88vw, 26rem);
    }
  }
</style>
