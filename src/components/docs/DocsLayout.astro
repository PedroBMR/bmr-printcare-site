---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsNav from './DocsNav.astro';
import { withBase } from '../../utils/paths';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  heading: string;
  intro: string;
  mode?: 'hub' | 'article';
}

const {
  title,
  description,
  eyebrow = 'Documentation in progress',
  heading,
  intro,
  mode = 'article',
} = Astro.props;
const isArticle = mode === 'article';
---

<BaseLayout title={title} description={description}>
  <main class:list={['page-shell', 'docs-page', isArticle && 'docs-page--article']}>
    <header class:list={['docs-page-header', isArticle ? 'docs-page-header--compact' : 'docs-page-header--hub']} aria-labelledby="docs-page-title">
      {isArticle && (
        <a class="docs-breadcrumb" href={withBase('/docs/')}>← Back to docs hub</a>
      )}
      <p class="section-eyebrow">{eyebrow}</p>
      <h1 id="docs-page-title">{heading}</h1>
      <p>{intro}</p>
    </header>

    <div class="docs-layout">
      <DocsNav />
      <article class="docs-content">
        <slot />
      </article>
    </div>
  </main>
</BaseLayout>
