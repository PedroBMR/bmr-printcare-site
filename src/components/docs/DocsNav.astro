---
import { normalizeRoute, withBase } from '../../utils/paths';

interface NavItem {
  href: string;
  label: string;
  status?: string;
}

interface Props {
  activePath?: string;
}

const { activePath = Astro.url.pathname } = Astro.props;
const normalizedActivePath = normalizeRoute(activePath);

const navItems: NavItem[] = [
  { href: '/docs/', label: 'Docs hub' },
  { href: '/docs/getting-started/', label: 'Getting started', status: 'Preview' },
  { href: '/docs/printer-profiles/', label: 'Printer profiles', status: 'Preview' },
  { href: '/docs/maintenance-history/', label: 'Maintenance history', status: 'Preview' },
  { href: '/docs/preventive-maintenance/', label: 'Preventive maintenance', status: 'Preview' },
  { href: '/docs/parts-and-consumables/', label: 'Parts and consumables', status: 'Preview' },
  { href: '/docs/local-first-data/', label: 'Local-first data', status: 'Preview' },
  { href: '/docs/catalogs/', label: 'Catalogs', status: 'Planned' },
  { href: '/docs/backup-and-restore/', label: 'Backup and restore', status: 'Planned' },
  { href: '/docs/troubleshooting/', label: 'Troubleshooting', status: 'Planned' },
];
---

<nav class="docs-nav" aria-label="Documentation navigation">
  <p class="docs-nav__label">Documentation</p>
  <ul>
    {navItems.map((item) => {
      const isActive = normalizedActivePath === normalizeRoute(item.href);

      return (
        <li>
          <a href={withBase(item.href)} aria-current={isActive ? 'page' : undefined}>
            <span>{item.label}</span>
            {item.status && <small>{item.status}</small>}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
