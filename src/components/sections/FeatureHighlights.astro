---
import { withBase } from '../../utils/paths';
const features = [
  {
    title: 'Printer profiles',
    icon: 'profiles',
    description: 'Keep printer-specific notes, service status, and maintenance context in one place.',
  },
  {
    title: 'Service history',
    icon: 'history',
    description: 'Record what happened, when it happened, and which parts or actions were involved.',
  },
  {
    title: 'Maintenance planning',
    icon: 'planning',
    description: 'Prepare recurring care routines so important work is visible before it is urgent.',
  },
  {
    title: 'Part records',
    icon: 'parts',
    description: 'Document replacements and wear items without relying on manufacturer branding or cloud tools.',
  },
];
---

<section class="section-shell" aria-labelledby="features-title">
  <div class="section-heading">
    <p class="section-eyebrow">Feature highlights</p>
    <h2 id="features-title">Designed around everyday maintenance decisions.</h2>
    <p>
      The full feature overview explains what is in development, what is planned, and which ideas remain roadmap-only
      while NozzleNote by BMR is being prepared.
    </p>
  </div>
  <div class="feature-grid">
    {features.map((feature) => (
      <article class="feature-card">
        <span class="feature-icon" aria-hidden="true" data-icon={feature.icon}>
          {feature.icon === 'profiles' && (
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M5 8.5h14l-1.1 7H6.1L5 8.5Z" />
              <path d="M8 8.5V6.75h8v1.75" />
              <path d="M8 17.5h8" />
              <path d="M8 12h8" />
            </svg>
          )}
          {feature.icon === 'history' && (
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M6.5 7.5A7 7 0 1 1 5 12" />
              <path d="M5 5v3.5h3.5" />
              <path d="M12 8.25v4l2.75 1.75" />
            </svg>
          )}
          {feature.icon === 'planning' && (
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M6.5 5.5h11a1.5 1.5 0 0 1 1.5 1.5v10.5a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 5 17.5V7a1.5 1.5 0 0 1 1.5-1.5Z" />
              <path d="M8 4v3" />
              <path d="M16 4v3" />
              <path d="M5 9h14" />
              <path d="m8 14 2 2 4.5-4.5" />
            </svg>
          )}
          {feature.icon === 'parts' && (
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M14.5 5.5a4 4 0 0 0 4 4l-9 9a2.1 2.1 0 0 1-3-3l9-9a4 4 0 0 0-1-1Z" />
              <path d="m12.25 12.25 2.5 2.5" />
              <path d="M5 19h4" />
            </svg>
          )}
        </span>
        <h3>{feature.title}</h3>
        <p>{feature.description}</p>
      </article>
    ))}
  </div>
  <a class="feature-overview-link" href={withBase('/features/')}>Explore the feature overview</a>
</section>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .feature-card {
    display: grid;
    align-content: start;
    gap: 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    background:
      radial-gradient(circle at top left, rgba(57, 208, 255, 0.08), transparent 11rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 32%),
      rgba(16, 22, 36, 0.72);
  }

  .feature-icon {
    display: inline-grid;
    width: 2.55rem;
    height: 2.55rem;
    place-items: center;
    border: 1px solid rgba(57, 208, 255, 0.3);
    border-radius: 0.95rem;
    background:
      radial-gradient(circle at 30% 15%, rgba(57, 208, 255, 0.18), transparent 68%),
      rgba(7, 10, 18, 0.36);
    color: var(--color-accent);
    box-shadow: 0 12px 26px rgba(57, 208, 255, 0.1);
  }

  .feature-icon[data-icon='planning'],
  .feature-icon[data-icon='parts'] {
    border-color: rgba(167, 139, 250, 0.32);
    color: var(--color-brand-violet-soft);
    box-shadow: 0 12px 26px rgba(124, 58, 237, 0.1);
  }

  .feature-icon svg {
    width: 1.38rem;
    height: 1.38rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  h3 {
    margin: 0;
    font-size: 1.15rem;
    letter-spacing: -0.025em;
    line-height: 1.16;
  }

  p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .section-heading p:not(.section-eyebrow) {
    max-width: 42rem;
    font-size: 1rem;
  }

  .feature-overview-link {
    display: inline-flex;
    width: fit-content;
    margin-top: 1.5rem;
    border: 1px solid rgba(57, 208, 255, 0.32);
    border-radius: 999px;
    padding: 0.8rem 1rem;
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
    font-weight: 900;
    text-decoration: none;
  }

  .feature-overview-link:hover,
  .feature-overview-link:focus-visible {
    border-color: rgba(57, 208, 255, 0.62);
    background: rgba(57, 208, 255, 0.12);
  }

  @media (max-width: 980px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
