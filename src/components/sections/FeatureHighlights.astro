---
const features = [
  {
    title: 'Printer profiles',
    description: 'Keep printer-specific notes, service status, and maintenance context in one place.',
  },
  {
    title: 'Service history',
    description: 'Record what happened, when it happened, and which parts or actions were involved.',
  },
  {
    title: 'Maintenance planning',
    description: 'Prepare recurring care routines so important work is visible before it is urgent.',
  },
  {
    title: 'Part records',
    description: 'Document replacements and wear items without relying on manufacturer branding or cloud tools.',
  },
];
---

<section class="section-shell" aria-labelledby="features-title">
  <div class="section-heading">
    <p class="section-eyebrow">Feature highlights</p>
    <h2 id="features-title">Designed around everyday maintenance decisions.</h2>
  </div>
  <div class="feature-grid">
    {features.map((feature) => (
      <article class="feature-card">
        <span aria-hidden="true"></span>
        <h3>{feature.title}</h3>
        <p>{feature.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .feature-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    background: rgba(16, 22, 36, 0.72);
  }

  .feature-card span {
    display: block;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.85rem;
    background: linear-gradient(135deg, rgba(57, 208, 255, 0.9), rgba(124, 58, 237, 0.9));
  }

  h3 {
    margin: 1.25rem 0 0;
    font-size: 1.15rem;
  }

  p {
    margin: 0.75rem 0 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 980px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
