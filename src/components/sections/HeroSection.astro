---
import { withBase } from '../../utils/paths';
---

<section class="hero-section section-shell" aria-labelledby="hero-title">
  <div class="hero-cinematic-field" aria-hidden="true">
    <span class="hero-light-rail hero-light-rail--cyan"></span>
    <span class="hero-light-rail hero-light-rail--violet"></span>
    <span class="hero-data-rail hero-data-rail--one"></span>
    <span class="hero-data-rail hero-data-rail--two"></span>
  </div>

  <div class="hero-content">
    <p class="section-eyebrow hero-reveal hero-reveal--eyebrow">Local-first maintenance logbook</p>
    <h1 id="hero-title" class="hero-reveal hero-reveal--title">
      <span>3D printer maintenance,</span> <span>without the guesswork.</span>
    </h1>
    <p class="hero-copy hero-reveal hero-reveal--copy">
      Track maintenance, parts, costs and history for your 3D printers — locally, privately and with verified
      catalogs planned as clearly separated optional content.
    </p>
    <ul class="trust-chips hero-reveal hero-reveal--chips" aria-label="Product trust principles">
      <li>Local-first</li>
      <li>Verified catalogs planned</li>
      <li>Private by default</li>
    </ul>
    <p class="hero-microcopy hero-reveal hero-reveal--microcopy">Your maintenance data is planned to stay on your device by default.</p>
    <div class="hero-actions hero-reveal hero-reveal--actions" aria-label="Primary landing page actions">
      <a class="primary-action" href={withBase('/roadmap/')}>View roadmap</a>
      <a class="secondary-action" href={withBase('/features/')}>Read product direction</a>
    </div>
  </div>

  <aside class="hero-panel hero-reveal hero-reveal--panel" aria-label="Product maintenance workspace preview">
    <span class="panel-edge-light" aria-hidden="true"></span>
    <span class="panel-scanline" aria-hidden="true"></span>

    <div class="panel-brand" aria-label="NozzleNote by BMR preview identity">
      <span class="panel-brand-mark" aria-hidden="true">
        <img
          src={withBase('/brand/nozzlenote-nn-symbol-64.png')}
          alt=""
          width="64"
          height="64"
          loading="lazy"
          decoding="async"
        />
      </span>
      <div>
        <strong>NozzleNote</strong>
        <span>by BMR</span>
      </div>
    </div>

    <div class="panel-header">
      <span class="status-dot" aria-hidden="true"></span>
      <span>Desktop app in development</span>
    </div>

    <div class="maintenance-card next-card">
      <span class="card-label">Next maintenance</span>
      <strong>Lubricate motion system</strong>
      <p>Track recurring tasks by printer, usage, and service notes.</p>
    </div>

    <div class="workspace-grid" aria-label="Maintenance workspace cards">
      <section class="mini-card history-card" aria-labelledby="history-preview-title">
        <span class="card-label">Recent service log</span>
        <h2 id="history-preview-title">History</h2>
        <ul>
          <li><span>Cleaned nozzle path</span><strong>Logged</strong></li>
          <li class="active-row"><span>Replaced PTFE tube</span><strong>Parts</strong></li>
          <li><span>Checked belt tension</span><strong>Notes</strong></li>
        </ul>
      </section>

      <section class="mini-card violet-card" aria-labelledby="parts-preview-title">
        <span class="card-label">Parts & costs</span>
        <h2 id="parts-preview-title">Summary</h2>
        <dl>
          <div>
            <dt>Consumables</dt>
            <dd>Tracked</dd>
          </div>
          <div>
            <dt>Catalog packs</dt>
            <dd>Planned</dd>
          </div>
        </dl>
      </section>
    </div>

    <dl class="hero-metrics">
      <div>
        <dt>Printers</dt>
        <dd>Personal &amp; growing setups</dd>
      </div>
      <div>
        <dt>Records</dt>
        <dd>Maintenance</dd>
      </div>
      <div>
        <dt>Data</dt>
        <dd>Local</dd>
      </div>
    </dl>
  </aside>
</section>

<style>
  .hero-section {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(20rem, 0.92fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding-top: clamp(4rem, 9vw, 7rem);
    perspective: 1200px;
    isolation: isolate;
  }

  .hero-section::before {
    position: absolute;
    z-index: -2;
    inset: clamp(0.35rem, 3vw, 1.5rem) -9vw auto -8vw;
    height: clamp(22rem, 48vw, 39rem);
    border-radius: 999px;
    opacity: 0.9;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 30% 42%, rgba(57, 208, 255, 0.24), transparent 45%),
      radial-gradient(ellipse at 72% 40%, rgba(124, 58, 237, 0.22), transparent 42%),
      radial-gradient(ellipse at 54% 58%, rgba(37, 99, 255, 0.12), transparent 46%),
      linear-gradient(110deg, transparent 16%, rgba(57, 208, 255, 0.075) 43%, rgba(124, 58, 237, 0.055) 58%, transparent 72%);
    content: '';
    filter: blur(4px);
  }

  .hero-section::after {
    position: absolute;
    z-index: -1;
    inset: 12% -7vw 8% 38%;
    opacity: 0.48;
    pointer-events: none;
    background:
      linear-gradient(115deg, transparent 0 32%, rgba(57, 208, 255, 0.18) 33%, transparent 34% 100%),
      repeating-linear-gradient(115deg, transparent 0 1.35rem, rgba(57, 208, 255, 0.06) 1.38rem, transparent 1.44rem),
      radial-gradient(ellipse at 68% 48%, rgba(124, 58, 237, 0.18), transparent 48%);
    clip-path: polygon(0 34%, 100% 0, 100% 64%, 9% 100%);
    content: '';
  }

  .hero-cinematic-field {
    position: absolute;
    z-index: -1;
    inset: 0;
    overflow: hidden;
    border-radius: calc(var(--radius-card) + 1rem);
    pointer-events: none;
  }

  .hero-light-rail,
  .hero-data-rail {
    position: absolute;
    display: block;
    pointer-events: none;
  }

  .hero-light-rail {
    right: clamp(14rem, 27vw, 27rem);
    width: clamp(12rem, 24vw, 23rem);
    height: 1px;
    opacity: 0.72;
    background: linear-gradient(90deg, transparent, rgba(57, 208, 255, 0.7), rgba(124, 58, 237, 0.52), transparent);
    box-shadow: 0 0 22px rgba(57, 208, 255, 0.16);
    transform-origin: right center;
  }

  .hero-light-rail--cyan {
    top: 38%;
    transform: rotate(-12deg);
  }

  .hero-light-rail--violet {
    top: 55%;
    opacity: 0.46;
    transform: rotate(10deg);
  }

  .hero-data-rail {
    width: clamp(9rem, 18vw, 17rem);
    height: 4.5rem;
    border-top: 1px solid rgba(57, 208, 255, 0.16);
    border-right: 1px solid rgba(124, 58, 237, 0.14);
    opacity: 0.58;
  }

  .hero-data-rail--one {
    right: 34%;
    bottom: 15%;
    transform: skewX(-22deg);
  }

  .hero-data-rail--two {
    top: 8%;
    right: 5%;
    transform: skewX(18deg) rotate(180deg);
  }

  .hero-content {
    max-width: 48rem;
    position: relative;
    z-index: 1;
  }

  .section-eyebrow {
    width: fit-content;
    border: 1px solid rgba(57, 208, 255, 0.22);
    border-radius: var(--radius-control);
    padding: 0.36rem 0.7rem;
    background: rgba(57, 208, 255, 0.06);
    box-shadow: 0 0 30px rgba(57, 208, 255, 0.08);
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3rem, 6.6vw, 5.9rem);
    letter-spacing: -0.062em;
    line-height: 0.98;
    text-wrap: balance;
  }

  h1 span {
    display: block;
  }

  .hero-copy {
    max-width: 41rem;
    margin: 1.5rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
  }

  .trust-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .trust-chips li {
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: var(--radius-control);
    padding: 0.5rem 0.8rem;
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 900;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .trust-chips li:nth-child(2) {
    border-color: rgba(124, 58, 237, 0.35);
    background: rgba(124, 58, 237, 0.1);
  }

  .hero-microcopy {
    max-width: 36rem;
    margin: 0.9rem 0 0;
    color: var(--color-text-soft);
    font-size: 0.95rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-control);
    padding: 0.9rem 1.2rem;
    font-weight: 900;
    text-align: center;
    text-decoration: none;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-standard),
      background var(--motion-duration-base) var(--motion-ease-standard);
  }

  .primary-action {
    border: 1px solid rgba(57, 208, 255, 0.58);
    background:
      linear-gradient(135deg, rgba(57, 208, 255, 0.98), rgba(37, 99, 255, 0.94) 48%, rgba(124, 58, 237, 0.96)),
      var(--gradient-brand);
    color: var(--color-text);
    box-shadow: 0 18px 50px rgba(37, 99, 255, 0.22), 0 0 0 1px rgba(57, 208, 255, 0.1);
  }

  .secondary-action {
    border: 1px solid rgba(57, 208, 255, 0.26);
    background:
      linear-gradient(135deg, rgba(57, 208, 255, 0.08), rgba(124, 58, 237, 0.08)),
      rgba(16, 22, 36, 0.7);
    color: var(--color-text);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .primary-action:hover,
  .primary-action:focus-visible,
  .secondary-action:hover,
  .secondary-action:focus-visible {
    border-color: rgba(57, 208, 255, 0.74);
    box-shadow: var(--shadow-cyan), 0 0 0 1px rgba(57, 208, 255, 0.12);
    transform: translateY(-2px);
  }

  .hero-panel {
    position: relative;
    display: grid;
    gap: 1rem;
    overflow: hidden;
    border: 1px solid rgba(57, 208, 255, 0.3);
    border-radius: calc(var(--radius-card) + 0.45rem);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), transparent 32%),
      radial-gradient(circle at 16% 6%, rgba(57, 208, 255, 0.25), transparent 15rem),
      radial-gradient(circle at 90% 15%, rgba(124, 58, 237, 0.24), transparent 17rem),
      linear-gradient(145deg, rgba(16, 22, 36, 0.97), rgba(21, 29, 46, 0.84));
    box-shadow: var(--shadow-hero-panel);
    transform-style: preserve-3d;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-glow) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .hero-panel:hover,
  .hero-panel:focus-within {
    border-color: rgba(57, 208, 255, 0.44);
    box-shadow:
      var(--shadow-soft),
      var(--shadow-violet),
      0 0 0 1px rgba(57, 208, 255, 0.1),
      0 28px 92px rgba(57, 208, 255, 0.14);
    transform: translateY(var(--motion-hover-raise));
  }

  .hero-panel::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(57, 208, 255, 0.075) 1px, transparent 1px),
      linear-gradient(90deg, rgba(57, 208, 255, 0.055) 1px, transparent 1px);
    background-size: 2.25rem 2.25rem;
    mask-image: linear-gradient(to bottom, black, transparent 86%);
    content: '';
  }

  .hero-panel::after {
    position: absolute;
    inset: auto -25% -45% auto;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: rgba(124, 58, 237, 0.3);
    content: '';
    filter: blur(34px);
  }

  .panel-edge-light,
  .panel-scanline {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  .panel-edge-light {
    inset: -1px;
    border-radius: inherit;
    background:
      linear-gradient(115deg, transparent 0 18%, rgba(57, 208, 255, 0.18) 31%, transparent 43% 100%),
      linear-gradient(220deg, transparent 0 55%, rgba(124, 58, 237, 0.2) 70%, transparent 88%);
    opacity: 0.56;
    mask-image: linear-gradient(#000, #000) content-box, linear-gradient(#000, #000);
    mask-composite: exclude;
    padding: 1px;
  }

  .panel-scanline {
    inset: 0;
    opacity: 0.22;
    background: linear-gradient(180deg, transparent 0 48%, rgba(57, 208, 255, 0.32) 50%, transparent 54% 100%);
    transform: translateY(-55%);
  }

  .panel-brand,
  .panel-header,
  .maintenance-card,
  .workspace-grid,
  .hero-metrics {
    position: relative;
    z-index: 2;
  }

  .panel-brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .panel-brand-mark {
    display: inline-grid;
    width: 3.4rem;
    height: 3.4rem;
    place-items: center;
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: 1.1rem;
    background:
      radial-gradient(circle at 30% 20%, rgba(57, 208, 255, 0.16), transparent 62%),
      rgba(7, 10, 18, 0.34);
    box-shadow: 0 14px 24px rgba(57, 208, 255, 0.18), 0 12px 26px rgba(124, 58, 237, 0.14);
  }

  .panel-brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .panel-brand div {
    display: grid;
    gap: 0.08rem;
  }

  .panel-brand strong {
    font-size: 1.05rem;
    letter-spacing: -0.02em;
  }

  .panel-brand span {
    color: var(--color-text-soft);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .panel-header {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid rgba(57, 208, 255, 0.22);
    border-radius: 999px;
    padding: 0.45rem 0.7rem;
    background: rgba(7, 10, 18, 0.34);
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 800;
    box-shadow: 0 0 26px rgba(57, 208, 255, 0.08);
  }

  .status-dot {
    position: relative;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 24px rgba(57, 208, 255, 0.75);
  }

  .status-dot::after {
    position: absolute;
    inset: -0.32rem;
    border: 1px solid rgba(57, 208, 255, 0.46);
    border-radius: inherit;
    opacity: 0.44;
    content: '';
  }

  .maintenance-card,
  .mini-card,
  .hero-metrics div {
    border: 1px solid var(--color-border);
    background: rgba(7, 10, 18, 0.32);
  }

  .maintenance-card {
    display: grid;
    gap: 0.65rem;
    border-radius: 1.25rem;
    padding: clamp(1.1rem, 3vw, 1.3rem);
  }

  .next-card {
    border-color: rgba(57, 208, 255, 0.32);
    background:
      radial-gradient(circle at top right, rgba(57, 208, 255, 0.16), transparent 12rem),
      linear-gradient(135deg, rgba(57, 208, 255, 0.065), rgba(124, 58, 237, 0.035)),
      rgba(7, 10, 18, 0.36);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.045), 0 18px 42px rgba(57, 208, 255, 0.08);
  }

  .card-label {
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .maintenance-card strong {
    display: block;
    max-width: 18rem;
    font-size: clamp(1.25rem, 3vw, 1.45rem);
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .maintenance-card p {
    max-width: 23rem;
    margin: 0;
    color: var(--color-text-muted);
  }

  .workspace-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 1rem;
  }

  .mini-card {
    display: grid;
    align-content: start;
    border-radius: 1rem;
    padding: 1rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
  }

  .mini-card h2 {
    margin: 0.4rem 0 0;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
  }

  .mini-card ul,
  .mini-card dl {
    display: grid;
    gap: 0.55rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
  }

  .mini-card li,
  .mini-card dl div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-radius: 0.72rem;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .history-card li {
    margin-inline: -0.35rem;
    padding: 0.35rem;
  }

  .history-card .active-row {
    border: 1px solid rgba(57, 208, 255, 0.2);
    background: linear-gradient(90deg, rgba(57, 208, 255, 0.12), rgba(124, 58, 237, 0.06), transparent);
    color: var(--color-text);
    box-shadow: 0 0 24px rgba(57, 208, 255, 0.08);
  }

  .mini-card li span,
  .mini-card dt {
    min-width: 0;
  }

  .mini-card strong,
  .mini-card dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .mini-card dt {
    color: var(--color-text-muted);
  }

  .violet-card {
    border-color: rgba(124, 58, 237, 0.3);
    background:
      radial-gradient(circle at bottom right, rgba(124, 58, 237, 0.18), transparent 10rem),
      rgba(7, 10, 18, 0.32);
  }

  .violet-card .card-label {
    color: var(--color-brand-violet-soft);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(2, minmax(0, 0.82fr));
    gap: 1rem;
    margin: 0;
  }

  .hero-metrics div {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    border-radius: 1rem;
    padding: 0.95rem;
  }

  .hero-metrics dt {
    color: var(--color-text-soft);
    font-size: 0.75rem;
  }

  .hero-metrics dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 900;
    line-height: 1.22;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-section::before {
      animation: hero-halo-breathe var(--motion-duration-glow-pulse) var(--motion-ease-ambient) infinite alternate;
    }

    .hero-section::after {
      animation: hero-beam-drift var(--motion-duration-light-sweep) var(--motion-ease-ambient) infinite alternate;
    }

    .hero-reveal {
      opacity: 0;
      transform: translate3d(0, var(--motion-entrance-distance), 0);
      animation: hero-cinematic-reveal var(--motion-duration-cinematic) var(--motion-ease-emphasized) both;
      animation-delay: calc(120ms + var(--motion-entrance-stagger) * var(--hero-reveal-order, 0));
    }

    .hero-reveal--eyebrow {
      --hero-reveal-order: 0;
    }

    .hero-reveal--title {
      --hero-reveal-order: 1;
    }

    .hero-reveal--copy {
      --hero-reveal-order: 2;
    }

    .hero-reveal--chips,
    .hero-reveal--microcopy {
      --hero-reveal-order: 3;
    }

    .hero-reveal--actions {
      --hero-reveal-order: 4;
    }

    .hero-reveal--panel {
      --hero-reveal-order: 3;
      transform: translate3d(1rem, 1.1rem, 0) rotateX(4deg) rotateY(-5deg) scale(0.985);
      animation-name: hero-panel-reveal, hero-panel-float;
      animation-duration: var(--motion-duration-cinematic), 9s;
      animation-timing-function: var(--motion-ease-emphasized), var(--motion-ease-ambient);
      animation-delay: calc(120ms + var(--motion-entrance-stagger) * var(--hero-reveal-order, 0)), 900ms;
      animation-fill-mode: both, none;
      animation-iteration-count: 1, infinite;
      animation-direction: normal, alternate;
    }

    .hero-light-rail::after {
      position: absolute;
      inset: -1px auto -1px 0;
      width: 30%;
      border-radius: 999px;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.82), transparent);
      content: '';
      animation: hero-rail-glint 7.5s var(--motion-ease-ambient) infinite;
    }

    .hero-light-rail--violet::after {
      animation-delay: 1.8s;
    }

    .panel-edge-light {
      animation: hero-panel-edge-breathe var(--motion-duration-glow-pulse) var(--motion-ease-ambient) infinite alternate;
    }

    .panel-scanline {
      animation: hero-scanline 8s linear infinite;
    }

    .status-dot::after {
      animation: hero-status-pulse var(--motion-duration-glow-pulse) var(--motion-ease-ambient) infinite;
    }

    .history-card .active-row {
      animation: hero-active-row-breathe 5.6s var(--motion-ease-ambient) infinite alternate;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-section::before,
    .hero-section::after,
    .hero-light-rail::after,
    .panel-edge-light,
    .panel-scanline,
    .status-dot::after,
    .history-card .active-row,
    .hero-reveal,
    .hero-reveal--panel {
      animation: none !important;
      transform: none !important;
    }

    .hero-reveal,
    .hero-reveal--panel {
      opacity: 1 !important;
    }

    .panel-scanline {
      opacity: 0;
    }
  }

  @keyframes hero-cinematic-reveal {
    from {
      opacity: 0;
      transform: translate3d(0, var(--motion-entrance-distance), 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes hero-panel-reveal {
    from {
      opacity: 0;
