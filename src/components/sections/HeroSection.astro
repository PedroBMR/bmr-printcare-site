---
import { withBase } from '../../utils/paths';
---

<section class="hero-section section-shell" aria-labelledby="hero-title">
  <div class="hero-content">
    <p class="section-eyebrow">Local-first maintenance logbook</p>
    <h1 id="hero-title"><span>3D printer maintenance,</span> <span>without the guesswork.</span></h1>
    <p class="hero-copy">
      Track maintenance, parts, costs and history for your 3D printers — locally, privately and with verified
      catalogs planned as clearly separated optional content.
    </p>
    <ul class="trust-chips" aria-label="Product trust principles">
      <li>Local-first</li>
      <li>Verified catalogs planned</li>
      <li>Private by default</li>
    </ul>
    <p class="hero-microcopy">Your maintenance data is planned to stay on your device by default.</p>
    <div class="hero-actions" aria-label="Primary landing page actions">
      <a class="primary-action" href={withBase('/roadmap/')}>View roadmap</a>
      <a class="secondary-action" href={withBase('/features/')}>Read product direction</a>
    </div>
  </div>

  <aside class="hero-panel" aria-label="Product maintenance workspace preview">
    <div class="panel-brand" aria-label="NozzleNote by BMR preview identity">
      <span class="panel-brand-mark" aria-hidden="true">
        <img
          src={withBase('/brand/nozzlenote-nn-symbol-64.png')}
          alt=""
          width="64"
          height="64"
          loading="lazy"
          decoding="async"
        />
      </span>
      <div>
        <strong>NozzleNote</strong>
        <span>by BMR</span>
      </div>
    </div>

    <div class="panel-header">
      <span class="status-dot" aria-hidden="true"></span>
      <span>Desktop app in development</span>
    </div>

    <div class="maintenance-card next-card">
      <span class="card-label">Next maintenance</span>
      <strong>Lubricate motion system</strong>
      <p>Track recurring tasks by printer, usage, and service notes.</p>
    </div>

    <div class="workspace-grid" aria-label="Maintenance workspace cards">
      <section class="mini-card" aria-labelledby="history-preview-title">
        <span class="card-label">Recent service log</span>
        <h2 id="history-preview-title">History</h2>
        <ul>
          <li><span>Cleaned nozzle path</span><strong>Logged</strong></li>
          <li><span>Replaced PTFE tube</span><strong>Parts</strong></li>
          <li><span>Checked belt tension</span><strong>Notes</strong></li>
        </ul>
      </section>

      <section class="mini-card violet-card" aria-labelledby="parts-preview-title">
        <span class="card-label">Parts & costs</span>
        <h2 id="parts-preview-title">Summary</h2>
        <dl>
          <div>
            <dt>Consumables</dt>
            <dd>Tracked</dd>
          </div>
          <div>
            <dt>Catalog packs</dt>
            <dd>Planned</dd>
          </div>
        </dl>
      </section>
    </div>

    <dl class="hero-metrics">
      <div>
        <dt>Printers</dt>
        <dd>Personal &amp; growing setups</dd>
      </div>
      <div>
        <dt>Records</dt>
        <dd>Maintenance</dd>
      </div>
      <div>
        <dt>Data</dt>
        <dd>Local</dd>
      </div>
    </dl>
  </aside>
</section>

<style>
  .hero-section {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(20rem, 0.88fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding-top: clamp(4rem, 9vw, 7rem);
  }

  .hero-content {
    max-width: 48rem;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3rem, 6.6vw, 5.9rem);
    letter-spacing: -0.062em;
    line-height: 0.98;
    text-wrap: balance;
  }

  h1 span {
    display: block;
  }

  .hero-copy {
    max-width: 41rem;
    margin: 1.5rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
  }

  .trust-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .trust-chips li {
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: var(--radius-control);
    padding: 0.5rem 0.8rem;
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 900;
  }

  .trust-chips li:nth-child(2) {
    border-color: rgba(124, 58, 237, 0.35);
    background: rgba(124, 58, 237, 0.1);
  }

  .hero-microcopy {
    max-width: 36rem;
    margin: 0.9rem 0 0;
    color: var(--color-text-soft);
    font-size: 0.95rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-control);
    padding: 0.85rem 1.15rem;
    font-weight: 900;
    text-align: center;
    text-decoration: none;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-base) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-standard);
  }

  .primary-action {
    border: 1px solid rgba(57, 208, 255, 0.5);
    background: var(--gradient-brand);
    color: var(--color-text);
    box-shadow: 0 18px 50px rgba(37, 99, 255, 0.22);
  }

  .secondary-action {
    border: 1px solid var(--color-border-strong);
    background: rgba(16, 22, 36, 0.66);
    color: var(--color-text);
  }

  .primary-action:hover,
  .primary-action:focus-visible,
  .secondary-action:hover,
  .secondary-action:focus-visible {
    border-color: rgba(57, 208, 255, 0.72);
    box-shadow: var(--shadow-cyan);
    transform: translateY(-1px);
  }

  .hero-panel {
    position: relative;
    display: grid;
    gap: 1rem;
    overflow: hidden;
    border: 1px solid rgba(57, 208, 255, 0.24);
    border-radius: calc(var(--radius-card) + 0.35rem);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent 30%),
      radial-gradient(circle at 18% 8%, rgba(57, 208, 255, 0.22), transparent 15rem),
      radial-gradient(circle at 92% 18%, rgba(124, 58, 237, 0.2), transparent 17rem),
      linear-gradient(145deg, rgba(16, 22, 36, 0.96), rgba(21, 29, 46, 0.8));
    box-shadow: var(--shadow-soft), var(--shadow-violet);
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-glow) var(--motion-ease-standard),
      transform var(--motion-duration-base) var(--motion-ease-hover);
  }

  .hero-panel:hover,
  .hero-panel:focus-within {
    border-color: rgba(57, 208, 255, 0.38);
    box-shadow: var(--shadow-soft), var(--shadow-violet), 0 0 0 1px rgba(57, 208, 255, 0.08);
    transform: translateY(var(--motion-hover-raise));
  }

  .hero-panel::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(57, 208, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(57, 208, 255, 0.05) 1px, transparent 1px);
    background-size: 2.25rem 2.25rem;
    mask-image: linear-gradient(to bottom, black, transparent 86%);
    content: '';
  }

  .hero-panel::after {
    position: absolute;
    inset: auto -25% -45% auto;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: rgba(124, 58, 237, 0.28);
    content: '';
    filter: blur(48px);
  }

  .panel-brand,
  .panel-header,
  .maintenance-card,
  .workspace-grid,
  .hero-metrics {
    position: relative;
    z-index: 1;
  }

  .panel-brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .panel-brand-mark {
    display: inline-grid;
    width: 3.4rem;
    height: 3.4rem;
    place-items: center;
    border: 1px solid rgba(57, 208, 255, 0.24);
    border-radius: 1.1rem;
    background:
      radial-gradient(circle at 30% 20%, rgba(57, 208, 255, 0.12), transparent 62%),
      rgba(7, 10, 18, 0.34);
    box-shadow: 0 14px 24px rgba(57, 208, 255, 0.16), 0 12px 26px rgba(124, 58, 237, 0.12);
  }

  .panel-brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .panel-brand div {
    display: grid;
    gap: 0.08rem;
  }

  .panel-brand strong {
    font-size: 1.05rem;
    letter-spacing: -0.02em;
  }

  .panel-brand span {
    color: var(--color-text-soft);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .panel-header {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid rgba(57, 208, 255, 0.18);
    border-radius: 999px;
    padding: 0.45rem 0.7rem;
    background: rgba(7, 10, 18, 0.28);
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .status-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 24px rgba(57, 208, 255, 0.75);
  }

  .maintenance-card,
  .mini-card,
  .hero-metrics div {
    border: 1px solid var(--color-border);
    background: rgba(7, 10, 18, 0.32);
  }

  .maintenance-card {
    display: grid;
    gap: 0.65rem;
    border-radius: 1.25rem;
    padding: clamp(1.1rem, 3vw, 1.3rem);
  }

  .next-card {
    border-color: rgba(57, 208, 255, 0.28);
    background:
      radial-gradient(circle at top right, rgba(57, 208, 255, 0.12), transparent 12rem),
      rgba(7, 10, 18, 0.34);
  }

  .card-label {
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .maintenance-card strong {
    display: block;
    max-width: 18rem;
    font-size: clamp(1.25rem, 3vw, 1.45rem);
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .maintenance-card p {
    max-width: 23rem;
    margin: 0;
    color: var(--color-text-muted);
  }

  .workspace-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 1rem;
  }

  .mini-card {
    display: grid;
    align-content: start;
    border-radius: 1rem;
    padding: 1rem;
  }

  .mini-card h2 {
    margin: 0.4rem 0 0;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
  }

  .mini-card ul,
  .mini-card dl {
    display: grid;
    gap: 0.55rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
  }

  .mini-card li,
  .mini-card dl div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .mini-card li span,
  .mini-card dt {
    min-width: 0;
  }

  .mini-card strong,
  .mini-card dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .mini-card dt {
    color: var(--color-text-muted);
  }

  .violet-card {
    border-color: rgba(124, 58, 237, 0.28);
    background:
      radial-gradient(circle at bottom right, rgba(124, 58, 237, 0.16), transparent 10rem),
      rgba(7, 10, 18, 0.32);
  }

  .violet-card .card-label {
    color: var(--color-brand-violet-soft);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(2, minmax(0, 0.82fr));
    gap: 1rem;
    margin: 0;
  }

  .hero-metrics div {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    border-radius: 1rem;
    padding: 0.95rem;
  }

  .hero-metrics dt {
    color: var(--color-text-soft);
    font-size: 0.75rem;
  }

  .hero-metrics dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 900;
    line-height: 1.22;
  }

  @media (max-width: 900px) {
    .hero-section {
      grid-template-columns: 1fr;
      padding-top: 3rem;
    }

    .hero-panel {
      max-width: 38rem;
    }
  }

  @media (max-width: 560px) {
    h1 {
      max-width: 12ch;
      font-size: clamp(2.45rem, 13.5vw, 3.75rem);
      letter-spacing: -0.052em;
      line-height: 1.02;
    }

    .hero-actions,
    .primary-action,
    .secondary-action {
      width: 100%;
    }

    .workspace-grid,
    .hero-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
