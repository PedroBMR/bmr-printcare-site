---
import { withBase } from '../../utils/paths';
---

<section class="hero-section section-shell" aria-labelledby="hero-title">
  <div class="hero-content">
    <p class="section-eyebrow">Local-first maintenance logbook</p>
    <h1 id="hero-title">3D printer maintenance, without the guesswork.</h1>
    <p class="hero-copy">
      Track maintenance, parts, costs and history for your 3D printers — locally, privately and with verified catalogs.
    </p>
    <ul class="trust-chips" aria-label="Product trust principles">
      <li>Local-first</li>
      <li>Verified catalogs</li>
      <li>Backup-ready</li>
    </ul>
    <p class="hero-microcopy">Your maintenance data is planned to stay on your device by default.</p>
    <div class="hero-actions" aria-label="Primary landing page actions">
      <a class="primary-action" href={withBase('/roadmap/')}>View roadmap</a>
      <a class="secondary-action" href={withBase('/features/')}>Read product direction</a>
    </div>
  </div>

  <aside class="hero-panel" aria-label="Product status preview">
    <div class="panel-header">
      <span class="status-dot" aria-hidden="true"></span>
      <span>Desktop app in development</span>
    </div>
    <div class="maintenance-card">
      <span class="card-label">Next maintenance</span>
      <strong>Lubricate motion system</strong>
      <p>Track recurring tasks by printer, usage, and service notes.</p>
    </div>
    <dl class="hero-metrics">
      <div>
        <dt>Printers</dt>
        <dd>1–5 setups</dd>
      </div>
      <div>
        <dt>Parts</dt>
        <dd>Documented</dd>
      </div>
      <div>
        <dt>Data</dt>
        <dd>Local</dd>
      </div>
    </dl>
  </aside>
</section>

<style>
  .hero-section {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding-top: clamp(4rem, 9vw, 7rem);
  }

  .hero-content {
    max-width: 48rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.75rem);
    letter-spacing: -0.075em;
    line-height: 0.88;
  }

  .hero-copy {
    max-width: 41rem;
    margin: 1.5rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
  }

  .trust-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .trust-chips li {
    border: 1px solid rgba(57, 208, 255, 0.28);
    border-radius: 999px;
    padding: 0.5rem 0.8rem;
    background: rgba(57, 208, 255, 0.08);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 900;
  }

  .hero-microcopy {
    max-width: 36rem;
    margin: 0.9rem 0 0;
    color: var(--color-text-soft);
    font-size: 0.95rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.85rem 1.15rem;
    font-weight: 800;
    text-align: center;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .primary-action {
    background: linear-gradient(135deg, var(--color-accent), #8ae8ff);
    color: #04111a;
    box-shadow: 0 18px 50px rgba(57, 208, 255, 0.2);
  }

  .secondary-action {
    border: 1px solid var(--color-border-strong);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
  }

  .primary-action:hover,
  .primary-action:focus-visible,
  .secondary-action:hover,
  .secondary-action:focus-visible {
    border-color: rgba(57, 208, 255, 0.62);
    box-shadow: 0 18px 50px rgba(57, 208, 255, 0.18);
    transform: translateY(-1px);
  }

  .hero-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: clamp(1.25rem, 4vw, 2rem);
    background:
      radial-gradient(circle at 20% 10%, rgba(57, 208, 255, 0.2), transparent 15rem),
      linear-gradient(145deg, rgba(16, 22, 36, 0.95), rgba(21, 29, 46, 0.76));
    box-shadow: var(--shadow-soft);
  }

  .hero-panel::after {
    position: absolute;
    inset: auto -25% -45% auto;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: rgba(124, 58, 237, 0.28);
    content: '';
    filter: blur(48px);
  }

  .panel-header,
  .maintenance-card,
  .hero-metrics {
    position: relative;
    z-index: 1;
  }

  .panel-header {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .status-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 24px rgba(57, 208, 255, 0.75);
  }

  .maintenance-card {
    margin-top: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.045);
  }

  .card-label {
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .maintenance-card strong {
    display: block;
    margin-top: 0.8rem;
    font-size: 1.45rem;
    letter-spacing: -0.03em;
  }

  .maintenance-card p {
    margin: 0.65rem 0 0;
    color: var(--color-text-muted);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 1rem 0 0;
  }

  .hero-metrics div {
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 0.9rem;
    background: rgba(255, 255, 255, 0.035);
  }

  .hero-metrics dt {
    color: var(--color-text-soft);
    font-size: 0.75rem;
  }

  .hero-metrics dd {
    margin: 0.3rem 0 0;
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .hero-section {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 9ch;
    }
  }

  @media (max-width: 520px) {
    .hero-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
