---
import AppPreviewFrame from '../content/AppPreviewFrame.astro';
---

<section class="section-shell solution-section" aria-labelledby="solution-title">
  <div class="solution-copy">
    <p class="section-eyebrow">The solution</p>
    <h2 id="solution-title">A focused desktop workspace for printer care records.</h2>
    <p>
      NozzleNote by BMR is being shaped as a practical maintenance hub: add printers, track service events, connect part
      changes to real history, and keep routine care visible before maintenance gets overlooked.
    </p>
  </div>

  <AppPreviewFrame
    title="NozzleNote maintenance workspace"
    label="Desktop app preview"
    status="Preview placeholder"
    pattern="maintenance"
    variant="desktop"
    caption="Interface preview placeholder. Final app screenshots will be added closer to release."
  />
</section>

<style>
  .solution-section {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(18rem, 1.14fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-card) + 0.5rem);
    padding: clamp(1.5rem, 5vw, 3rem);
    background:
      radial-gradient(circle at 78% 20%, rgba(124, 58, 237, 0.16), transparent 21rem),
      linear-gradient(135deg, rgba(57, 208, 255, 0.12), rgba(124, 58, 237, 0.12)),
      rgba(16, 22, 36, 0.58);
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-glow) var(--motion-ease-standard);
  }

  .solution-section:hover,
  .solution-section:focus-within {
    border-color: rgba(57, 208, 255, 0.32);
    box-shadow: 0 22px 70px rgba(124, 58, 237, 0.1);
  }

  .solution-copy {
    min-width: 0;
  }

  p:not(.section-eyebrow) {
    max-width: 42rem;
    margin: 1.2rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
  }

  @media (max-width: 900px) {
    .solution-section {
      grid-template-columns: 1fr;
    }
  }
</style>
