---
import { withBase } from '../../utils/paths';
import DocsGrid from '../../components/docs/DocsGrid.astro';
import DocsLayout from '../../components/docs/DocsLayout.astro';

const beginnerGuides = [
  {
    title: 'Getting started',
    href: '/docs/getting-started/',
    description:
      'Understand what PrintKeep by BMR is intended to help with, what is still in development, and how to prepare for a first printer record.',
  },
  {
    title: 'Printer profiles',
    href: '/docs/printer-profiles/',
    description:
      'Learn how printer profiles are planned to organize printer identity, notes, and maintenance context without implying manufacturer affiliation.',
  },
  {
    title: 'Maintenance history',
    href: '/docs/maintenance-history/',
    description:
      'Review the intended maintenance record workflow for dates, service notes, parts, and workshop observations.',
  },
  {
    title: 'Preventive maintenance',
    href: '/docs/preventive-maintenance/',
    description:
      'See how preventive task planning is expected to help users remember routine checks without replacing hands-on inspection.',
  },
  {
    title: 'Parts and consumables',
    href: '/docs/parts-and-consumables/',
    description:
      'Explore the planned approach for tracking replacement parts, consumables, vendors, and practical notes in a conservative way.',
  },
  {
    title: 'Local-first data',
    href: '/docs/local-first-data/',
    description:
      'Read the current direction for local data ownership, backups, exports, and responsible expectations while the app is being built.',
  },
];
---

<DocsLayout
  title="Documentation | PrintKeep by BMR"
  description="Beginner-friendly documentation hub in progress for PrintKeep by BMR, a local-first desktop app for 3D printer maintenance tracking."
  heading="A practical documentation hub for printer maintenance records."
  intro="PrintKeep by BMR is still in development, so this documentation is an early static guide structure rather than final product instructions. The goal is to explain the intended maintenance workflow clearly, conservatively, and without promising public availability yet."
  mode="hub"
>
  <section class="docs-section" aria-labelledby="docs-guides-title">
    <div class="section-heading">
      <p class="section-eyebrow">Beginner guides</p>
      <h2 id="docs-guides-title">Start with the core maintenance topics.</h2>
      <p>
        These draft guides introduce the most important concepts for a local-first 3D printer maintenance tracker. They
        avoid public download steps because the app is not publicly available yet.
      </p>
    </div>
    <DocsGrid items={beginnerGuides} ariaLabel="Beginner documentation guides" />
  </section>

  <section class="docs-section" aria-labelledby="docs-workflow-title">
    <div class="section-heading">
      <p class="section-eyebrow">Maintenance workflow</p>
      <h2 id="docs-workflow-title">A simple path through the planned product.</h2>
    </div>
    <ol class="docs-steps">
      <li>
        <strong>Create a printer profile.</strong>
        <span>Use a profile to keep the printer identity, model notes, and maintenance context in one place.</span>
      </li>
      <li>
        <strong>Record maintenance events.</strong>
        <span>Add dated notes when you clean, inspect, adjust, replace, or observe something important.</span>
      </li>
      <li>
        <strong>Plan preventive work.</strong>
        <span>Use planned reminders as helpful prompts, not as machine-made fault findings or safety assurances.</span>
      </li>
      <li>
        <strong>Review history before decisions.</strong>
        <span>Look back at previous repairs, parts, and notes before changing hardware or tuning a workflow.</span>
      </li>
    </ol>
  </section>

  <section class="content-panel" aria-labelledby="docs-roadmap-title">
    <h2 id="docs-roadmap-title">Roadmap-only topics</h2>
    <p>
      Some ideas, such as deeper catalogs, calibration notes, exports, and release packaging, are still roadmap topics.
      They should be treated as planned direction until a future milestone documents implemented behavior.
    </p>
    <ul class="link-list">
      <li><a href={withBase('/features/')}>Review the feature overview</a></li>
      <li><a href={withBase('/roadmap/')}>Check the public roadmap</a></li>
      <li><a href={withBase('/download/')}>Review release preparation</a></li>
      <li><a href={withBase('/support/')}>See current support expectations</a></li>
    </ul>
  </section>

  <section class="status-note status-note--accent" aria-labelledby="docs-independence-title">
    <h2 id="docs-independence-title">Independent product note</h2>
    <p>
      PrintKeep by BMR is an independent product and is not affiliated with, endorsed by, sponsored by, or officially
      connected to Bambu Lab, Creality, Anycubic, Prusa, or any other 3D printer manufacturer. Documentation may use
      general printer maintenance language, but it must not imply affiliation or endorsement.
    </p>
  </section>
</DocsLayout>
