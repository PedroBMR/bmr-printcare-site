---
import { withBase } from '../../utils/paths';
import DocsGrid from '../../components/docs/DocsGrid.astro';
import AppPreviewFrame from '../../components/content/AppPreviewFrame.astro';
import DocsLayout from '../../components/docs/DocsLayout.astro';
const guides = [
  { title: 'Getting started', href: '/docs/getting-started/', status: 'Preview', description: 'Understand what NozzleNote by BMR is intended to help with while the app is still in development.' },
  { title: 'Printer profiles', href: '/docs/printer-profiles/', status: 'Preview', description: 'Preview how printer records are planned to organize identity, setup notes, and maintenance context.' },
  { title: 'Maintenance history', href: '/docs/maintenance-history/', status: 'Preview', description: 'Review the intended dated maintenance-record workflow for service notes, parts, and observations.' },
  { title: 'Preventive maintenance', href: '/docs/preventive-maintenance/', status: 'Preview', description: 'See how planned care prompts may support routine checks without replacing inspection or judgement.' },
  { title: 'Parts and consumables', href: '/docs/parts-and-consumables/', status: 'Preview', description: 'Explore the planned approach for replacement parts, consumables, vendors, and practical notes.' },
  { title: 'Local-first data', href: '/docs/local-first-data/', status: 'Preview', description: 'Read the current direction for local-first app records, backups, exports, and website analytics separation.' },
  { title: 'Catalogs', href: '/docs/catalogs/', status: 'Planned', description: 'Learn how optional BMR Verified Catalogs are planned and why they are not manufacturer validated.' },
  { title: 'Backup and restore', href: '/docs/backup-and-restore/', status: 'Planned', description: 'Future backup and restore documentation direction; app behavior is not final yet.' },
  { title: 'Troubleshooting', href: '/docs/troubleshooting/', status: 'Planned', description: 'Planned troubleshooting documentation scope for app records, not printer repair or manufacturer service.' },
];
---
<DocsLayout
  title="Documentation Preview | NozzleNote by BMR"
  description="Documentation preview for NozzleNote by BMR, an independent desktop app in development for 3D printer maintenance tracking."
  eyebrow="Documentation preview"
  heading="Documentation preview for planned maintenance workflows."
  intro="NozzleNote by BMR is still in development. These guides are early documentation previews and release-preparation notes, not final product instructions or a public download announcement."
  mode="hub"
>
  <section class="docs-section" aria-labelledby="docs-guides-title">
    <div class="section-heading">
      <p class="section-eyebrow">Start here</p>
      <h2 id="docs-guides-title">Core guides and planned topics.</h2>
      <p>Visible labels use Preview, Planned, or Release preparation until app behavior is implemented and public.</p>
    </div>
    <DocsGrid items={guides} ariaLabel="Documentation preview and planned guide cards" />
  </section>

  <section class="docs-section docs-section--with-preview" aria-labelledby="docs-workflow-title">
    <div class="section-heading">
      <p class="section-eyebrow">Workflow preview</p>
      <h2 id="docs-workflow-title">A simple path through the planned product.</h2>
      <p>The preview is intentionally schematic and does not represent final app screenshots.</p>
    </div>
    <AppPreviewFrame
      title="Documentation workflow preview"
      label="Guide UI preview"
      status="Preview placeholder"
      pattern="docs"
      variant="compact"
      caption="Screenshot placeholder — final app screenshots will be added closer to beta readiness."
    />
    <ol class="docs-steps">
      <li>
        <strong>Create a printer profile.</strong>
        <span>Keep printer identity, setup notes, and maintenance context in one place.</span>
      </li>
      <li>
        <strong>Record maintenance events.</strong>
        <span>Add dated notes when you clean, inspect, adjust, replace, or observe something important.</span>
      </li>
      <li>
        <strong>Plan preventive work.</strong>
        <span>Use planned reminders as prompts, not safety guarantees or machine-made findings.</span>
      </li>
      <li>
        <strong>Review history before decisions.</strong>
        <span>Use records to understand what changed before making maintenance decisions.</span>
      </li>
    </ol>
  </section>

  <section class="status-note status-note--accent" aria-labelledby="docs-independence-title">
    <h2 id="docs-independence-title">Manufacturer disclaimer</h2>
    <p>NozzleNote by BMR is independent and is not affiliated with, endorsed by, sponsored by, certified by, reviewed by, or officially connected to any 3D printer manufacturer.</p>
    <ul class="link-list">
      <li><a href={withBase('/manufacturer-disclaimer/')}>Read the full manufacturer disclaimer</a></li>
    </ul>
  </section>
</DocsLayout>
