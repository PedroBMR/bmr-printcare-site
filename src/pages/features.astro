---
import { withBase } from '../utils/paths';
import FeatureGrid from '../components/content/FeatureGrid.astro';
import AppPreviewFrame from '../components/content/AppPreviewFrame.astro';
import StatusNote from '../components/content/StatusNote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const coreFeatures = [
  { title: 'Maintenance history', status: 'Core direction', description: 'Record dated maintenance events, service notes, parts used, consumables, observations, and follow-up context for each printer.' },
  { title: 'Preventive maintenance', status: 'Core direction', description: 'Plan recurring care prompts for cleaning, inspection, lubrication, replacement checks, and other routine work without treating reminders as safety guarantees.' },
  { title: 'Parts and consumables', status: 'Core direction', description: 'Keep practical records for nozzles, build surfaces, filters, lubricant, replacement parts, vendors, and notes that help explain printer history.' },
];

const profileFeatures = [
  { title: 'Printer profiles', status: 'In development', description: 'Printer profiles are planned as the starting point for manufacturer-independent printer identity, setup notes, installed parts, and maintenance context.' },
  { title: 'Flexible model details', status: 'Planned', description: 'Future profile fields may describe selected printer families and user-owned equipment without manufacturer logos or partnership claims.' },
  { title: 'Workshop context', status: 'Planned', description: 'Profiles may later capture usage notes, location, accessories, and other context that makes maintenance records easier to interpret.' },
];

const directionItems = [
  { title: 'Local-first app data', status: 'Direction', description: 'NozzleNote is being developed as a desktop app with maintenance records planned to stay local by default.' },
  { title: 'Verified catalogs', status: 'Planned optional content', description: 'BMR Verified Catalogs are planned as optional content packs maintained by BMR for content quality and organization, not manufacturer approval.' },
  { title: 'Conservative workflow', status: 'Product goal', description: 'The product direction favors clear records, careful labels, and human review over broad compatibility or automated diagnosis promises.' },
];

const roadmapOnlyItems = [
  { title: 'Calibration tracking', status: 'Roadmap-only', description: 'Calibration notes and related history are future ideas, not current release commitments.' },
  { title: 'Print-quality tracking', status: 'Roadmap-only', description: 'Print-quality observations may be explored later; no photo-based analysis, automated diagnostic conclusions, or automated fault findings are promised.' },
  { title: 'Direct printer integrations', status: 'Roadmap-only', description: 'Optional read-only connectors may be evaluated in the future, but no live integration, cloud sync, mobile app, or account system exists.' },
];
---

<BaseLayout
  title="Features | NozzleNote by BMR"
  description="Feature direction for NozzleNote by BMR, an independent desktop app in development for local-first 3D printer maintenance tracking."
>
  <main class="page-shell feature-page">
    <section class="page-hero" aria-labelledby="features-title">
      <p class="section-eyebrow">Feature overview</p>
      <h1 id="features-title">Clear maintenance records before bigger product promises.</h1>
      <p>
        NozzleNote by BMR is being developed as an independent desktop maintenance tracker. This page separates core direction from planned and roadmap-only ideas.
      </p>
      <div class="hero-actions" aria-label="Feature page links">
        <a class="primary-link" href={withBase('/docs/')}>Read docs</a>
        <a class="secondary-link" href={withBase('/roadmap/')}>View roadmap</a>
        <a class="secondary-link" href={withBase('/pricing/')}>View pricing direction</a>
      </div>
    </section>

    <section class="feature-section" aria-labelledby="core-title">
      <div class="section-heading"><p class="section-eyebrow">Core maintenance tracking</p><h2 id="core-title">The planned foundation is a practical service history.</h2><p>Core features focus on records users can review and maintain themselves.</p></div>
      <FeatureGrid items={coreFeatures} ariaLabel="Core maintenance tracking features" />
    </section>

    <section class="feature-section" aria-labelledby="profiles-title">
      <div class="section-heading"><p class="section-eyebrow">Printer profiles</p><h2 id="profiles-title">Each printer needs its own context.</h2><p>Profiles are planned to organize printer-specific history without implying manufacturer affiliation.</p></div>
      <FeatureGrid items={profileFeatures} ariaLabel="Printer profile features" />
    </section>

    <section class="feature-section" aria-labelledby="direction-title">
      <div class="section-heading"><p class="section-eyebrow">Product direction</p><h2 id="direction-title">Local-first records and optional future content.</h2><p>Future resources must remain clearly labeled until they are implemented and reviewed.</p></div>
      <FeatureGrid items={directionItems} ariaLabel="Product direction items" />
    </section>

    <section class="feature-section" aria-labelledby="roadmap-only-title">
      <div class="section-heading"><p class="section-eyebrow">Roadmap-only features</p><h2 id="roadmap-only-title">Exploration areas are not live features.</h2><p>These ideas may change, ship later, or never ship.</p></div>
      <FeatureGrid items={roadmapOnlyItems} ariaLabel="Roadmap-only feature ideas" />
    </section>

    <AppPreviewFrame title="Feature overview preview" label="Interface preview" status="Preview placeholder" pattern="maintenance" variant="desktop" caption="Feature overview placeholder. Final screenshots will be added closer to release." />

    <StatusNote title="Manufacturer independence" tone="accent">
      <p>NozzleNote by BMR is independent and is not affiliated with, endorsed by, sponsored by, certified by, reviewed by, or officially connected to any 3D printer manufacturer.</p>
    </StatusNote>
  </main>
</BaseLayout>
