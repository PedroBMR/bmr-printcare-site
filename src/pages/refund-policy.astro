---
import { withBase } from '../utils/paths';
import LegalLayout from '../components/legal/LegalLayout.astro';
import LegalSection from '../components/legal/LegalSection.astro';
---

<LegalLayout
  title="Draft Refund Policy | BMR PrintCare"
  description="Preliminary refund policy placeholder explaining that BMR PrintCare currently has no purchases, paid plans, checkout, or public app release."
  eyebrow="Draft refund policy"
  heading="Preliminary refund policy placeholder."
  intro="This draft avoids promising refunds or commercial terms before BMR PrintCare has a public release, purchase flow, or paid plan."
  currentPath="/refund-policy/"
>
  <LegalSection title="No purchases currently available">
    <p>
      BMR PrintCare is still in development. The current website does not offer purchases, paid plans, subscriptions,
      checkout, app store distribution, license keys, invoices, or public download links. Because there is no active
      payment flow, there is no current refund process to request through this site.
    </p>
  </LegalSection>

  <LegalSection title="Future policy required before commercial release">
    <p>
      If a future milestone introduces paid access, app store distribution, subscriptions, one-time purchases, license
      seats, trials, or paid support, a reviewed refund policy should be published before accepting payments. That policy
      should explain eligibility, timing, platform-specific rules, exclusions, support contacts, and any applicable legal
      requirements.
    </p>
  </LegalSection>

  <LegalSection title="No app store or processor terms yet">
    <p>
      This placeholder does not describe Apple, Microsoft, Stripe, PayPal, marketplace, reseller, or other payment
      processor refund rules because no such distribution or checkout integration is currently part of the website.
    </p>
  </LegalSection>

  <LegalSection title="Where to check status">
    <p>
      Current availability is explained on the <a href={withBase('/download/')}>release preparation page</a>. Support expectations
      are drafted in the <a href={withBase('/support/')}>support hub</a>, and product sequencing is listed on the
      <a href={withBase('/roadmap/')}>roadmap</a>.
    </p>
  </LegalSection>
</LegalLayout>
