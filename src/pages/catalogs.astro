---
import { withBase } from '../utils/paths';
import FeatureGrid from '../components/content/FeatureGrid.astro';
import StatusNote from '../components/content/StatusNote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const scopeItems = [
  { title: 'Printer profile templates', status: 'Planned', description: 'Catalogs may include starting profile details for selected printer families after model coverage is defined.' },
  { title: 'Maintenance routine suggestions', status: 'Planned', description: 'Suggested care routines may help users start organized records, but users remain responsible for checking manufacturer documentation and printer condition.' },
  { title: 'Parts and consumables notes', status: 'Planned', description: 'Optional catalog content may organize common wear items and service notes for selected models without claiming universal compatibility.' },
];

const boundaries = [
  { title: 'Not available yet', status: 'Current status', description: 'No verified catalog is publicly available, paid, bundled, or downloadable today.' },
  { title: 'Not manufacturer validated', status: 'Independence', description: 'Verified means reviewed and maintained by BMR for internal content quality and organization; it does not mean approved or supported by manufacturers.' },
  { title: 'Selected models only', status: 'Compatibility caution', description: 'Future compatibility should use narrow language such as compatible with selected Bambu Lab printer models only after coverage is defined.' },
];
---

<BaseLayout
  title="Catalog Planning | NozzleNote by BMR"
  description="Catalog planning for NozzleNote by BMR. BMR Verified Catalogs are planned optional content packs and are not available and are not manufacturer validated."
>
  <main class="page-shell feature-page">
    <section class="page-hero" aria-labelledby="catalogs-title">
      <p class="section-eyebrow">Catalog planning</p>
      <h1 id="catalogs-title">Verified catalogs are planned optional content, not live resources.</h1>
      <p>
        NozzleNote by BMR may later offer BMR Verified Catalogs to help users start organized maintenance records. Catalogs are not public, paid, bundled, downloadable, or manufacturer supported today.
      </p>
      <div class="hero-actions" aria-label="Catalog links">
        <a class="primary-link" href={withBase('/roadmap/')}>View roadmap</a>
        <a class="secondary-link" href={withBase('/pricing/')}>View pricing direction</a>
        <a class="secondary-link" href={withBase('/manufacturer-disclaimer/')}>Read manufacturer disclaimer</a>
      </div>
    </section>

    <StatusNote title="Planned first concept" tone="accent">
      <p>
        BMR Verified Catalog — Compatible with selected Bambu Lab printer models is a future concept only. Model coverage, content scope, pricing, licensing, support, and update expectations are not final.
      </p>
    </StatusNote>

    <section class="feature-section" aria-labelledby="verified-meaning-title">
      <div class="section-heading">
        <p class="section-eyebrow">Verified definition</p>
        <h2 id="verified-meaning-title">Verified means BMR content review, not manufacturer validation.</h2>
        <p>
          “Verified” means reviewed and maintained by BMR for internal content quality and organization. It does not mean verified, approved, certified, reviewed, endorsed, or supported by any 3D printer manufacturer.
        </p>
      </div>
      <FeatureGrid items={scopeItems} ariaLabel="Planned catalog scope" />
    </section>

    <section class="feature-section" aria-labelledby="catalog-boundaries-title">
      <div class="section-heading"><p class="section-eyebrow">Catalog boundaries</p><h2 id="catalog-boundaries-title">The catalog model remains preliminary.</h2><p>Catalogs must stay optional, clearly separated from the app’s core recordkeeping, and conservative about compatibility.</p></div>
      <FeatureGrid items={boundaries} ariaLabel="Catalog boundaries" />
    </section>
  </main>
</BaseLayout>
