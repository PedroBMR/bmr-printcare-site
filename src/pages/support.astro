---
import { withBase } from '../utils/paths';
import FeatureGrid from '../components/content/FeatureGrid.astro';
import FaqList from '../components/content/FaqList.astro';
import StatusNote from '../components/content/StatusNote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
const scope = [
  { title: 'Website and release-preparation questions', status: 'Current scope', description: 'Current support is limited to public website context, roadmap clarity, and release-preparation information.' },
  { title: 'App support', status: 'Future', description: 'App-specific support will be defined after a public release exists.' },
  { title: 'Catalog support', status: 'Future', description: 'Verified catalog support is not active because catalogs are not available yet.' },
];
const out = [
  { title: 'Printer repair and warranty', status: 'Out of scope', description: 'NozzleNote by BMR does not provide manufacturer service, repair, warranty, safety, or hands-on troubleshooting support.' },
  { title: 'Manufacturer channels', status: 'Out of scope', description: 'This website is not a manufacturer service portal and cannot speak for Bambu Lab, Creality, Anycubic, Prusa, or any other manufacturer.' },
  { title: 'Emergency or safety support', status: 'Out of scope', description: 'Users should stop using unsafe equipment and consult qualified help or manufacturer documentation when safety is involved.' },
];
const faqs = [
  { question: 'Is there a support desk?', answer: 'No. A support desk or form is not live yet. Future support channels will be defined before public release.' },
  { question: 'Can I get help repairing my printer?', answer: 'NozzleNote is planned for maintenance records and planning. It is not a repair service or warranty channel.' },
  { question: 'Can I download the app for support testing?', answer: 'No public download is available yet. Release preparation will be updated when public files exist.' },
];
---
<BaseLayout title="Support | NozzleNote by BMR" description="Support expectations for NozzleNote by BMR while the app is in development. No support desk, repair service, or manufacturer channel is live.">
  <main class="page-shell feature-page">
    <section class="page-hero" aria-labelledby="support-title"><p class="section-eyebrow">Support status</p><h1 id="support-title">Current support is limited while the app is in development.</h1><p>NozzleNote by BMR does not yet have a public app release, helpdesk, support form, paid support plan, or manufacturer service channel.</p><div class="hero-actions"><a class="primary-link" href={withBase('/docs/')}>Read docs</a><a class="secondary-link" href={withBase('/download/')}>Release preparation</a></div></section>
    <StatusNote title="Before asking for support" tone="accent"><p>Please check the documentation preview, roadmap, release preparation page, and manufacturer disclaimer. Do not share private printer records, maintenance records, license data, payment data, or personal content through public channels.</p></StatusNote>
    <section class="feature-section"><div class="section-heading"><p class="section-eyebrow">Current support scope</p><h2>What can be covered today.</h2></div><FeatureGrid items={scope} ariaLabel="Current and future support scope" /></section>
    <section class="feature-section"><div class="section-heading"><p class="section-eyebrow">Out of scope</p><h2>What NozzleNote support does not cover.</h2></div><FeatureGrid items={out} ariaLabel="Out-of-scope support topics" /></section>
    <section class="feature-section"><div class="section-heading"><p class="section-eyebrow">FAQ</p><h2>Current limitations.</h2></div><FaqList items={faqs} ariaLabel="Support FAQ" /></section>
  </main>
</BaseLayout>
