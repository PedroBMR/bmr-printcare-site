---
import { withBase } from '../utils/paths';
import BaseLayout from '../layouts/BaseLayout.astro';

const roadmapItems = [
  {
    title: 'Website foundation',
    status: 'Completed',
    description: 'Static Astro foundation, landing page sections, and reusable layout components.',
  },
  {
    title: 'Documentation structure',
    status: 'Completed',
    description: 'Initial documentation hub, support route, roadmap route, header, footer, and navigation structure.',
  },
  {
    title: 'Product features and positioning',
    status: 'Completed',
    description: 'Initial feature overview route with conservative, manufacturer-independent product explanations.',
  },
  {
    title: 'Documentation hub expansion',
    status: 'Completed',
    description: 'Beginner-friendly static guide pages for core maintenance concepts and local-first data direction.',
  },
  {
    title: 'Support and release readiness',
    status: 'Completed',
    description: 'Static support hub, release-readiness checklist, FAQ content, and conservative download placeholder messaging.',
  },
  {
    title: 'Legal and compliance placeholders',
    status: 'In progress',
    description: 'Draft privacy, terms, license, refund, and manufacturer disclaimer pages for future legal review.',
  },
];
---

<BaseLayout
  title="Roadmap | PrintKeep by BMR"
  description="Public roadmap placeholder for PrintKeep by BMR website milestones and planned desktop app availability."
>
  <main class="page-shell">
    <section class="page-hero" aria-labelledby="roadmap-title">
      <p class="section-eyebrow">Roadmap</p>
      <h1 id="roadmap-title">Public release is planned, not available yet.</h1>
      <p>
        PrintKeep by BMR is being prepared in careful milestones. This page keeps the current website direction visible
        without promising download dates, integrations, or manufacturer partnerships.
      </p>
    </section>

    <section class="content-grid" aria-label="Roadmap milestones">
      {roadmapItems.map((item) => (
        <article class="content-card">
          <span class="status-pill">{item.status}</span>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
        </article>
      ))}
    </section>

    <section class="content-panel" aria-labelledby="roadmap-note-title">
      <h2 id="roadmap-note-title">Release note</h2>
      <p>
        No real download links are published yet. Future milestones should add availability details only when the app,
        documentation, support expectations, and basic legal pages are reviewed. The current feature direction is summarized
        on the <a href={withBase('/features/')}>features page</a>, early guide drafts are available in the
        <a href={withBase('/docs/')}>documentation hub</a>, current availability notes are listed on the
        <a href={withBase('/download/')}>release preparation page</a>, and preliminary legal placeholders begin with the
        <a href={withBase('/privacy/')}>draft privacy notice</a>.
      </p>
    </section>
  </main>
</BaseLayout>
