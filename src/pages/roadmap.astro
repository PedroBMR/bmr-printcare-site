---
import { withBase } from '../utils/paths';
import BaseLayout from '../layouts/BaseLayout.astro';

const completedItems = [
  {
    title: 'Website foundation',
    status: 'Completed',
    description: 'Static Astro foundation, GitHub Pages base-path support, landing page sections, and reusable layout components.',
  },
  {
    title: 'Documentation structure',
    status: 'Completed',
    description: 'Improved documentation hub, static guide pages, and smoother docs navigation for early product education.',
  },
  {
    title: 'Support and legal placeholders',
    status: 'In progress',
    description: 'Support guidance and preliminary legal pages exist as draft placeholders for future review before public release.',
  },
  {
    title: 'App development in progress',
    status: 'In progress',
    description: 'PrintKeep by BMR remains in development as a local-first desktop maintenance logbook for 3D printer owners.',
  },
];

const currentFocusItems = [
  'Desktop maintenance core',
  'Printer profiles',
  'Tasks',
  'History',
  'Parts',
  'Incidents',
  'Backup',
  'Catalog foundation',
];

const releasePathItems = [
  'Free Core public desktop release',
  'Website + docs + support guidance',
  'No paid catalog until reviewed',
];

const commercialPathItems = [
  'BMR Verified Catalog — Compatible with Bambu Lab Printers',
  'License key activation',
  'Entitlements',
  'Early supporter / crowdfunding campaign',
  'Public paid catalog launch',
];

const expansionItems = [
  'Maintenance Budget & Parts Planner',
  'Calibration & Print Quality Suite',
  'Print Quality Benchmark',
  'Optional account',
  'Optional sync',
  'Mobile companion',
  'Read-only integrations',
];

const calibrationSubareas = [
  'Machine Calibration',
  'Filament Calibration',
  'Filament Profiles',
  'Calibration History',
  'Print Quality Benchmark',
];

const benchmarkDetails = ['manual comparison', 'photo history', 'defect tags', 'quality notes'];

const connectorIdeas = [
  'OctoPrint',
  'Klipper / Moonraker',
  'PrusaLink',
  'Bambu-related integration, if technically and legally appropriate',
];
---

<BaseLayout
  title="Product Roadmap | PrintKeep by BMR"
  description="Product-focused roadmap for PrintKeep by BMR covering current development direction, planned release path, future verified catalogs, and future expansion ideas."
>
  <main class="page-shell feature-page">
    <section class="page-hero" aria-labelledby="roadmap-title">
      <p class="section-eyebrow">Product roadmap</p>
      <h1 id="roadmap-title">Current direction, planned work, and future ideas are separated.</h1>
      <p>
        PrintKeep by BMR is being developed as a local-first maintenance logbook for 3D printer owners. This roadmap uses
        cautious planning language and should not be read as a promise of availability, pricing, release dates,
        manufacturer support, or future integrations.
      </p>
      <div class="hero-actions" aria-label="Roadmap page links">
        <a class="primary-link" href={withBase('/catalogs/')}>Explore catalog planning</a>
        <a class="secondary-link" href={withBase('/download/')}>Read release preparation</a>
        <a class="secondary-link" href={withBase('/early-supporters/')}>Early Supporters concept</a>
      </div>
    </section>

    <section class="feature-section" aria-labelledby="completed-title">
      <div class="section-heading">
        <p class="section-eyebrow">Completed / In progress</p>
        <h2 id="completed-title">Website groundwork exists while the app continues toward a desktop core.</h2>
        <p>
          These items describe current project state. Legal content remains preliminary and the public desktop app is not
          published yet.
        </p>
      </div>
      <section class="content-grid" aria-label="Completed and in-progress roadmap areas">
        {completedItems.map((item) => (
          <article class="content-card">
            <span class="status-pill">{item.status}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </section>
    </section>

    <section class="content-panel" aria-labelledby="current-focus-title">
      <h2 id="current-focus-title">Current development focus</h2>
      <p>
        The current focus is the desktop maintenance core and the data structures needed to make manual printer care
        records useful before expanding into paid catalog content or optional connected workflows.
      </p>
      <ul class="plain-list roadmap-columns">
        {currentFocusItems.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="content-grid" aria-label="Release and commercial path roadmap">
      <article class="content-card">
        <span class="status-pill">Planned</span>
        <h2>Planned public release path</h2>
        <p>
          The release path is intended to start with a free Core desktop app for manual maintenance tracking and clear
          website, docs, and support guidance.
        </p>
        <ul class="plain-list">
          {releasePathItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="content-card">
        <span class="status-pill">Future roadmap</span>
        <h2>Future commercial path</h2>
        <p>
          Paid catalog work is a future path and should only move forward after review. An early supporter or crowdfunding-style
          campaign may later become a future commercial path to help fund launch preparation, but it is not live and rewards
          are not final. Paid catalog availability, pricing, licensing and update periods are not final yet.
        </p>
        <ul class="plain-list">
          {commercialPathItems.map((item) => <li>{item}</li>)}
          <li><a href={withBase('/early-supporters/')}>Review the Early Supporters planning placeholder</a></li>
        </ul>
      </article>

      <article class="content-card">
        <span class="status-pill">Future expansion</span>
        <h2>Future expansion areas</h2>
        <p>
          These ideas may later extend PrintKeep after the maintenance core is complete. They are not current features.
        </p>
        <ul class="plain-list">
          {expansionItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>

    <section class="content-panel" aria-labelledby="budget-title">
      <span class="status-pill">Future expansion</span>
      <h2 id="budget-title">Maintenance Budget & Parts Planner</h2>
      <p>
        A future Maintenance Budget & Parts Planner is planned to help users record part costs, suppliers, delivery lead
        times and expected replacement cycles.
      </p>
      <p>
        If a nozzle is usually replaced every six months, PrintKeep may later help remind the user before the replacement
        is due, show the last paid price, and suggest buying the part early enough to avoid downtime.
      </p>
    </section>

    <section class="content-panel" aria-labelledby="calibration-title">
      <span class="status-pill">Future expansion</span>
      <h2 id="calibration-title">Calibration & Print Quality Suite</h2>
      <p>
        After the maintenance core is complete, PrintKeep may expand into calibration and print quality tracking, helping
        users record machine calibration, filament calibration, profiles and quality observations over time.
      </p>
      <ul class="plain-list roadmap-columns">
        {calibrationSubareas.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="content-panel" aria-labelledby="benchmark-title">
      <span class="status-pill">Future expansion</span>
      <h2 id="benchmark-title">Print Quality Benchmark</h2>
      <p>
        A future Print Quality Benchmark may allow users to print a standard test model, upload reference photos, tag
        visible defects and compare print quality over time after maintenance, calibration, part changes or filament
        changes.
      </p>
      <ul class="plain-list roadmap-columns">
        {benchmarkDetails.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="content-panel" aria-labelledby="connectors-title">
      <span class="status-pill">Distant future</span>
      <h2 id="connectors-title">Future optional read-only printer connectors</h2>
      <p>
        Future optional read-only printer connectors may help turn real printer usage into better maintenance reminders,
        such as print-hour based routines or event-based care prompts.
      </p>
      <p>
        PrintKeep is not planned as a printer control platform. Any future connector should support maintenance insight,
        not replace slicers, dashboards or manufacturer tools.
      </p>
      <ul class="plain-list roadmap-columns">
        {connectorIdeas.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="content-panel" aria-labelledby="account-mobile-title">
      <span class="status-pill">Future roadmap</span>
      <h2 id="account-mobile-title">Future account, license, sync, and mobile language</h2>
      <p>
        A future optional PrintKeep account may help users recover licenses, manage activated devices, link older license
        keys, and prepare optional sync or mobile features.
      </p>
      <p>
        Before a full account system exists, paid catalogs may be activated through license keys and device activation.
      </p>
      <p>
        A future mobile companion may help users review tasks, scan QR codes, record quick incidents and receive
        maintenance reminders after account and sync infrastructure exists.
      </p>
    </section>

    <section class="content-panel" aria-labelledby="roadmap-note-title">
      <h2 id="roadmap-note-title">Release note</h2>
      <p>
        No real download links are published yet. Future milestones should add availability details only when the app,
        documentation, support expectations, and basic legal pages are reviewed. Planned BMR Verified Catalogs are
        described on the <a href={withBase('/catalogs/')}>catalogs page</a>, the current feature direction is summarized
        on the <a href={withBase('/features/')}>features page</a>, early guide drafts are available in the
        <a href={withBase('/docs/')}>documentation hub</a>, and current availability notes are listed on the
        <a href={withBase('/download/')}>release preparation page</a>.
      </p>
    </section>
  </main>
</BaseLayout>
