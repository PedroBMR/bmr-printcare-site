---
import { withBase } from '../utils/paths';
import ReleaseChecklist from '../components/content/ReleaseChecklist.astro';
import FeatureGrid from '../components/content/FeatureGrid.astro';
import StatusNote from '../components/content/StatusNote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const currentItems = [
  { title: 'Public website foundation', status: 'Completed', description: 'Root-domain deployment, Premium Violet Tech direction, preview placeholders, conditional GA4, and page structure are in place.' },
  { title: 'Content alignment', status: 'In progress', description: 'Public copy is being aligned to cautious product, commercial, documentation, and preliminary legal language.' },
  { title: 'Release preparation', status: 'In development', description: 'The app, screenshots, installers, support workflow, and reviewed legal/commercial terms are not public yet.' },
];
const releasePath = [
  { title: 'Finish app behavior', status: 'Planned', description: 'Validate printer profiles, maintenance history, preventive maintenance, parts records, local data behavior, and backup direction.' },
  { title: 'Prepare public assets', status: 'Planned', description: 'Add real screenshots, release notes, installer information, checksums if needed, and platform requirements only when available.' },
  { title: 'Review legal and support pages', status: 'Required', description: 'Commercial terms, privacy details, support expectations, refunds, and license terms need qualified review before paid features.' },
  { title: 'Publish download path', status: 'Future', description: 'A public download path will appear only after files exist and release preparation is complete.' },
];
const futureCards = [
  { title: 'Maintenance Budget & Parts Planner', status: 'Future expansion', description: 'May later help users estimate recurring parts and consumables needs without promising full accounting or procurement automation.' },
  { title: 'Calibration & Print Quality Suite', status: 'Roadmap-only', description: 'May later organize calibration notes and print-quality observations; no automated diagnostic conclusions or photo-based analysis is promised.' },
  { title: 'Print Quality Benchmark', status: 'Roadmap-only', description: 'May later provide structured benchmark notes, not automatic quality scoring or guaranteed issue detection.' },
  { title: 'Optional read-only printer connectors', status: 'Future evaluation', description: 'May later explore limited read-only integrations. No direct printer integration, remote control, or cloud sync is live.' },
  { title: 'Account, license, sync and mobile', status: 'Future planning', description: 'These areas remain planning-only and would require reviewed privacy, security, commercial, and support language before launch.' },
  { title: 'Future commercial path', status: 'Preliminary', description: 'Core, Pro, verified catalogs, and bundles are pricing direction only. No active paid plan or catalog exists.' },
];
---
<BaseLayout title="Roadmap | NozzleNote by BMR" description="Roadmap for NozzleNote by BMR, an independent 3D printer maintenance tracking app in development. No dates, downloads, paid plans, or integrations are live yet.">
  <main class="page-shell feature-page">
    <section class="page-hero" aria-labelledby="roadmap-title">
      <p class="section-eyebrow">Roadmap</p>
      <h1 id="roadmap-title">Current focus, planned release path, and future ideas.</h1>
      <p>NozzleNote by BMR is in development. This roadmap avoids firm dates and separates completed website work from app release preparation and future expansion areas.</p>
      <div class="hero-actions"><a class="primary-link" href={withBase('/download/')}>Read release preparation</a><a class="secondary-link" href={withBase('/pricing/')}>View pricing direction</a></div>
    </section>
    <StatusNote title="Release note" tone="accent"><p>No public download, paid catalog, Pro plan, account system, cloud sync, mobile app, or printer integration is live. Future items may change before release.</p></StatusNote>
    <section class="roadmap-section-group"><div class="section-heading"><p class="section-eyebrow">Completed / in progress</p><h2>Website foundation and current development focus.</h2></div><ReleaseChecklist items={currentItems} ariaLabel="Completed and in-progress roadmap items" /></section>
    <section class="roadmap-section-group"><div class="section-heading"><p class="section-eyebrow">Planned public release path</p><h2>What needs to happen before files are public.</h2></div><ReleaseChecklist items={releasePath} ariaLabel="Planned public release path" /></section>
    <section class="feature-section"><div class="section-heading"><p class="section-eyebrow">Future expansion areas</p><h2>Ideas under consideration after the foundation is ready.</h2><p>These cards are roadmap-only unless a future release explicitly implements them.</p></div><FeatureGrid items={futureCards} ariaLabel="Future expansion roadmap cards" /></section>
  </main>
</BaseLayout>
