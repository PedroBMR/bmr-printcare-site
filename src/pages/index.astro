---
import FeatureHighlights from '../components/sections/FeatureHighlights.astro';
import DisclaimerSection from '../components/sections/DisclaimerSection.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import LocalFirstSection from '../components/sections/LocalFirstSection.astro';
import ProblemSection from '../components/sections/ProblemSection.astro';
import RoadmapCta from '../components/sections/RoadmapCta.astro';
import SolutionSection from '../components/sections/SolutionSection.astro';
import WorkflowPreview from '../components/sections/WorkflowPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="BMR PrintCare | 3D Printer Maintenance Tracking"
  description="BMR PrintCare is a local-first desktop app for tracking 3D printer maintenance, parts, and service history."
>
  <main class="home-page">
    <HeroSection />
    <ProblemSection />
    <SolutionSection />
    <FeatureHighlights />
    <LocalFirstSection />
    <WorkflowPreview />
    <DisclaimerSection />
    <RoadmapCta />
  </main>
</BaseLayout>
