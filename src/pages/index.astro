---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="BMR PrintCare | 3D Printer Maintenance Tracking"
  description="BMR PrintCare is a local-first desktop app for tracking 3D printer maintenance, parts, and service history."
>
  <main class="home-shell" aria-labelledby="page-title">
    <section class="hero-card">
      <p class="eyebrow">Milestone 0 setup</p>
      <h1 id="page-title">BMR PrintCare website foundation</h1>
      <p class="intro">
        A clean Astro and TypeScript starter for the official BMR PrintCare landing page and documentation hub.
      </p>
      <p class="status">The full website experience will be designed in upcoming milestones.</p>
    </section>
  </main>
</BaseLayout>

<style>
  .home-shell {
    display: grid;
    min-height: 100vh;
    place-items: center;
    padding: var(--space-page);
  }

  .hero-card {
    width: min(100%, 48rem);
    padding: clamp(2rem, 6vw, 4rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: linear-gradient(145deg, rgba(16, 22, 36, 0.92), rgba(21, 29, 46, 0.72));
    box-shadow: var(--shadow-soft);
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3rem, 9vw, 6.5rem);
    letter-spacing: -0.08em;
    line-height: 0.9;
  }

  .intro {
    max-width: 38rem;
    margin: 1.5rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
  }

  .status {
    display: inline-flex;
    margin: 2rem 0 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(7, 10, 18, 0.4);
    color: var(--color-text);
    font-size: 0.95rem;
  }
</style>
