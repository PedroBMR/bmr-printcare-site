---
import { withBase } from '../utils/paths';
import ReleaseChecklist from '../components/content/ReleaseChecklist.astro';
import StatusNote from '../components/content/StatusNote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
const checklist = [
  { title: 'App behavior validated', status: 'Planned', description: 'Core maintenance workflows must be tested before release.' },
  { title: 'Real screenshots prepared', status: 'Planned', description: 'Preview placeholders will be replaced only with actual app screenshots.' },
  { title: 'Installer and platform notes', status: 'Planned', description: 'Public files, requirements, version notes, and checksums will be added only when available.' },
  { title: 'Legal and support review', status: 'Required', description: 'Terms, privacy, license, refund, and support expectations must be reviewed before commercial availability.' },
];
---
<BaseLayout title="Release Preparation | NozzleNote by BMR" description="NozzleNote by BMR is in development. No public download, installer, binary, checksum, or release date is available yet.">
  <main class="page-shell feature-page">
    <section class="page-hero" aria-labelledby="download-title"><p class="section-eyebrow">Release preparation</p><h1 id="download-title">No public download is available yet.</h1><p>This page is intentionally a release preparation page, not a live download page. No installer, binary, checksum, or public release date is being published here.</p><div class="hero-actions"><a class="primary-link" href={withBase('/roadmap/')}>View roadmap</a><a class="secondary-link" href={withBase('/docs/')}>Read documentation preview</a></div></section>
    <StatusNote title="Current status" tone="accent"><p>NozzleNote by BMR is still in development. Download links will be added only after release files exist and public release language is reviewed.</p></StatusNote>
    <section class="roadmap-section-group"><div class="section-heading"><p class="section-eyebrow">Planned release checklist</p><h2>What to expect before download.</h2><p>Future release notes should explain platform support, installation, local data behavior, backups, known limitations, and support expectations.</p></div><ReleaseChecklist items={checklist} ariaLabel="Planned release checklist" /></section>
    <section class="content-panel"><span class="status-pill">Safety and data note</span><h2>Users remain responsible for printer maintenance decisions.</h2><p>NozzleNote is being designed for recordkeeping and planning. It is not a safety system, repair service, warranty channel, or manufacturer service portal. App maintenance records are planned to stay local by default.</p></section>
  </main>
</BaseLayout>
