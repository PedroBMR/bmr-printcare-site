---
import { withBase } from '../utils/paths';
import ReleaseChecklist from '../components/content/ReleaseChecklist.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const releaseChecklistItems = [
  {
    title: 'Windows build',
    status: 'Planned',
    description:
      'The first public package is planned to start with a clearly labeled Windows desktop build after packaging work is ready.',
  },
  {
    title: 'Version number',
    status: 'Required',
    description:
      'Any future release should include a visible version number so documentation, known limitations, and support notes can refer to the same build.',
  },
  {
    title: 'Installer or portable package',
    status: 'Planned',
    description:
      'The package format is not final yet. A future release should explain whether users receive an installer, a portable package, or both.',
  },
  {
    title: 'Release notes',
    status: 'Required',
    description:
      'Release notes should describe included Core workflows, what remains planned, and what is not available yet.',
  },
  {
    title: 'Known limitations',
    status: 'Required',
    description:
      'Known limitations should be listed before files are published, including unsupported workflows, roadmap-only ideas, and model coverage boundaries.',
  },
  {
    title: 'Backup guidance',
    status: 'Required',
    description:
      'Local-first users should receive clear guidance for manual backups, restore expectations, and data-location notes before public files are posted.',
  },
  {
    title: 'Support scope',
    status: 'Required',
    description:
      'Support notes should clarify which app questions may be covered and which printer service, warranty, safety, or manufacturer issues remain outside scope.',
  },
  {
    title: 'Manufacturer disclaimer',
    status: 'Required',
    description:
      'Release copy must state that PrintKeep by BMR is independent and not affiliated with, endorsed by, sponsored by, or officially connected to manufacturers.',
  },
  {
    title: 'Privacy notice',
    status: 'Required',
    description:
      'Privacy language should be reviewed before any account, licensing, diagnostic, support intake, cloud, mobile, analytics, or payment workflow launches.',
  },
  {
    title: 'Terms and license placeholders reviewed',
    status: 'Required',
    description:
      'Draft terms, license, refund, and disclaimer pages should be reviewed before public distribution or any commercial flow is introduced.',
  },
];

const expectations = [
  'PrintKeep is not publicly available yet.',
  'No real download links, installers, binaries, checksums, purchase links, signup forms, or release dates are available from this page.',
  'The first public release is planned to focus on the free desktop Core: printer profiles, maintenance tasks, history, parts, incidents, and local backup.',
  'Optional paid verified catalogs and early supporter funding are future roadmap directions and are not part of a public checkout flow on this website.',
  'The app is intended for maintenance records and planning, not direct printer control, manufacturer service, or machine-driven diagnosis.',
];
---

<BaseLayout
  title="Download and Release Preparation | PrintKeep by BMR"
  description="Conservative PrintKeep by BMR download placeholder explaining that public release is not available yet and listing release-readiness requirements."
>
  <main class="page-shell">
    <section class="page-hero" aria-labelledby="download-title">
      <p class="section-eyebrow">Release preparation</p>
      <h1 id="download-title">PrintKeep is not publicly available yet.</h1>
      <p>
        PrintKeep by BMR is still in development. This page explains the planned release path for the first public desktop
        Core and keeps expectations conservative until real release files, notes, support scope, and reviewed legal text
        are ready.
      </p>
      <div class="hero-actions" aria-label="Release preparation links">
        <a class="primary-link" href={withBase('/roadmap/')}>View the roadmap</a>
        <a class="secondary-link" href={withBase('/catalogs/')}>Review catalog planning</a>
        <a class="secondary-link" href={withBase('/support/')}>Read support guidance</a>
        <a class="secondary-link" href={withBase('/early-supporters/')}>Early Supporters concept</a>
      </div>
    </section>

    <section class="status-banner" aria-label="Download status summary">
      <span class="status-pill">No public files yet</span>
      <p>
        <strong>No installer, binary, checksum, checkout, signup form, or release date is published here.</strong> This
        page is a readiness checklist for future release preparation, not an active download flow.
      </p>
    </section>

    <section class="content-panel" aria-labelledby="availability-title">
      <h2 id="availability-title">No public download yet</h2>
      <p>
        This is a release-preparation placeholder, not a file download page. The first public release is planned to focus
        on the free desktop Core: printer profiles, maintenance tasks, history, parts, incidents, and local backup. Those
        plans remain in development and do not mean files are ready today.
      </p>
      <p>
        Real download links should be added only after packaging, versioning, documentation, known limitations, backup
        guidance, support boundaries, manufacturer-independence language, and draft legal placeholders are reviewed.
      </p>
    </section>

    <section class="feature-section" aria-labelledby="checklist-title">
      <div class="section-heading">
        <p class="section-eyebrow">Planned release checklist</p>
        <h2 id="checklist-title">What should be ready before files are published?</h2>
        <p>
          These items keep the release message practical, beginner-friendly, and cautious. They do not announce a launch
          date or provide download files.
        </p>
      </div>
      <ReleaseChecklist items={releaseChecklistItems} ariaLabel="Download release readiness checklist" />
    </section>

    <section class="content-panel" aria-labelledby="expect-title">
      <h2 id="expect-title">What to expect before download</h2>
      <ul class="plain-list">
        {expectations.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="content-panel" aria-labelledby="safety-title">
      <h2 id="safety-title">Safety and data note</h2>
      <p>
        PrintKeep by BMR is planned as a local-first desktop maintenance tracker. Users should keep their own backups,
        follow printer manuals and safety guidance, and treat maintenance reminders as helpful planning prompts rather
        than assurances, official service instructions, or machine-made fault findings.
      </p>
    </section>

    <section class="content-panel" aria-labelledby="legal-readiness-title">
      <h2 id="legal-readiness-title">Legal readiness placeholders</h2>
      <p>
        Preliminary legal pages have been added for planning and future review. They are draft placeholders only and do
        not announce public availability, paid plans, final license terms, refund terms, or legal compliance.
      </p>
      <ul class="link-list">
        <li><a href={withBase('/privacy/')}>Draft privacy notice</a></li>
        <li><a href={withBase('/terms/')}>Draft terms of use</a></li>
        <li><a href={withBase('/license-terms/')}>Draft license terms</a></li>
        <li><a href={withBase('/refund-policy/')}>Draft refund policy</a></li>
        <li><a href={withBase('/manufacturer-disclaimer/')}>Manufacturer disclaimer</a></li>
      </ul>
    </section>

    <section class="content-panel" aria-labelledby="next-links-title">
      <h2 id="next-links-title">Helpful next links</h2>
      <ul class="link-list">
        <li><a href={withBase('/support/')}>Support scope and limitations</a></li>
        <li><a href={withBase('/roadmap/')}>Roadmap and release sequencing</a></li>
        <li><a href={withBase('/catalogs/')}>Planned verified catalog direction</a></li>
        <li><a href={withBase('/manufacturer-disclaimer/')}>Manufacturer independence disclaimer</a></li>
      </ul>
    </section>
  </main>
</BaseLayout>
