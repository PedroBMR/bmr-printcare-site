---
import { stripBase, withBase } from '../utils/paths';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import AmbientBackground from '../components/layout/AmbientBackground.astro';
import GoogleAnalytics from '../components/layout/GoogleAnalytics.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonicalPath = stripBase(Astro.url.pathname);
const canonicalUrl = Astro.site ? new URL(canonicalPath, Astro.site).href : undefined;
const socialImageUrl = Astro.site ? new URL(withBase('/brand/nozzlenote-nn-symbol-512.png'), Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    {canonicalUrl && !noindex && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:site_name" content="NozzleNote by BMR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && !noindex && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:locale" content="en_US" />
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    <meta property="og:image:alt" content="NozzleNote by BMR logo mark" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <meta name="twitter:image:alt" content="NozzleNote by BMR logo mark" />

    <meta name="theme-color" content="#070A12" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('/brand/favicon-32.png')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <title>{title}</title>
    <GoogleAnalytics />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <AmbientBackground />
    <SiteHeader />
    <div id="main-content" tabindex="-1">
      <slot />
    </div>
    <SiteFooter />
    <CookieConsent />
  </body>
</html>
